{
  "name": "@guestpost/integrations",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./providers": "./dist/providers/index.js",
    "./services": "./dist/services/index.js",
    "./workers": "./dist/workers/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest"
  },
  "dependencies": {
    "@guestpost/database": "workspace:*",
    "@guestpost/shared": "workspace:*",
    "bullmq": "^5.0.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^26.0.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^6.0.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["<rootDir>/src/**/*.spec.ts"],
    "moduleFileExtensions": ["ts", "js"]
  }
}