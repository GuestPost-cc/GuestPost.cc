generator client {
  provider = "prisma-client"
  output   = "../src/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  CUSTOMER
  PUBLISHER
  STAFF
}

enum CustomerRole {
  OWNER
  MEMBER
}

enum PublisherRole {
  PUBLISHER_OWNER
  PUBLISHER_MEMBER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_REFUNDED
  RESOLVED_REJECTED
  RESOLVED_RESTORED
}

enum StaffRole {
  SUPER_ADMIN
  OPERATIONS
  FINANCE
}

// Deprecated: kept for migration compatibility, will be removed
enum UserRole {
  OWNER
  MANAGER
  SEO_SPECIALIST
  CLIENT_VIEWER
  PUBLISHER
  ADMIN
}

// Deprecated: kept for migration compatibility, will be removed
enum MemberRole {
  OWNER
  MANAGER
  SEO_SPECIALIST
  CLIENT_VIEWER
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ContentOrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum RevisionStatus {
  REQUESTED
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
  DRAFT
}

enum WebsiteOwnershipType {
  PUBLISHER
  PLATFORM
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  SUBMITTED
  ACCEPTED
  CONTENT_REQUESTED
  CONTENT_CREATION
  CONTENT_READY
  CUSTOMER_REVIEW
  APPROVED
  PUBLISHED
  VERIFIED
  DELIVERED
  SETTLED
  COMPLETED
  CANCELLED
  REFUNDED
  DISPUTED
}

enum ServiceType {
  GUEST_POST
  NICHE_EDIT
  EDITORIAL_LINK
  OUTREACH_LINK
  LOCAL_CITATION
  FOUNDATION_LINK
  BLOG_ARTICLE
  SEO_CONTENT
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  RESOLVED
  CLOSED
}

enum OrderEventType {
  ORDER_CREATED
  ITEM_ADDED
  ITEM_REMOVED
  PAYMENT_SUBMITTED
  ORDER_SUBMITTED
  PAYMENT_CAPTURED
  ORDER_ACCEPTED
  CONTENT_REQUESTED
  CONTENT_SUBMITTED
  CONTENT_MARKED_READY
  CONTENT_SUBMITTED_FOR_REVIEW
  CONTENT_APPROVED
  REVISION_REQUESTED
  PUBLICATION_MARKED
  VERIFIED_AUTO
  VERIFIED_MANUAL
  DELIVERY_CONFIRMED
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  ORDER_CANCELLED
  REFUND_ISSUED
  SETTLEMENT_CREATED
  SETTLED
  REFUNDED
}

enum SettlementStatus {
  PENDING
  UNDER_REVIEW
  CUSTOMER_APPROVED
  ADMIN_APPROVED
  RELEASED
  CANCELLED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
  FAILED
  REVERSED
}

enum PayoutExecutionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum PayoutBatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  PARTIALLY_COMPLETED
  FAILED
}

enum PublisherTier {
  NEW
  TRUSTED
  VERIFIED
}

// Marketplace listing-service availability. WAITLIST is orderable=false but
// favoritable (MarketplaceFavorite.serviceType captures interest); a worker
// notifies interested users when the row flips to AVAILABLE.
enum ServiceAvailability {
  AVAILABLE
  PAUSED
  WAITLIST
}

// Snapshotted onto Order at creation. Downstream routing (publisher inbox vs
// internal Ops queue, settlement vs PlatformRevenue) keys off this column,
// never re-derives from Website.ownershipType — which can change after the
// order exists.
enum FulfillmentChannel {
  PUBLISHER
  PLATFORM
}

enum VerificationStatus {
  PENDING
  VERIFIED
  FAILED
  DISPUTED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  userType      UserType  @default(CUSTOMER)
  role          UserRole  @default(SEO_SPECIALIST)
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships          Membership[]
  publisherMemberships PublisherMembership[]
  staffMemberships     StaffMembership[]
  ownedOrders          Order[]               @relation("OrderCustomer")
  assignedOrders       Order[]               @relation("OrderAssignee")
  orderEvents          OrderEvent[]
  publications         Publication[]         @relation("PublicationVerifier")
  approvedWithdrawals  Withdrawal[]          @relation("WithdrawalApprover")
  tickets              Ticket[]
  messages             TicketMessage[]
  notifications        Notification[]
  auditLogs            AuditLog[]
  sessions             Session[]
  accounts             Account[]
  marketplaceReviews   MarketplaceReview[]
  marketplaceFavorites MarketplaceFavorite[]
  activeContext        ActiveContext?
  managedWebsites      Website[]             @relation("WebsiteManager")
  assignedTickets      Ticket[]              @relation("TicketAssignee")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

model ActiveContext {
  id                   String  @id @default(cuid())
  userId               String  @unique
  activeOrganizationId String?
  activePublisherId    String?

  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganization Organization? @relation(fields: [activeOrganizationId], references: [id], onDelete: SetNull)
  activePublisher    Publisher?    @relation(fields: [activePublisherId], references: [id], onDelete: SetNull)

  @@index([activeOrganizationId])
  @@index([activePublisherId])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships         Membership[]
  teams               Team[]
  publishers          Publisher[]
  campaigns           Campaign[]
  wallets             Wallet[]
  orders              Order[]
  tickets             Ticket[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  apiKeys             ApiKey[]
  marketplaceListings MarketplaceListing[]
  activeContexts      ActiveContext[]
}

enum MembershipStatus {
  PENDING
  ACTIVE
}

model Membership {
  id             String           @id @default(cuid())
  role           CustomerRole     @default(MEMBER)
  // PENDING until the invited user accepts. Only ACTIVE memberships grant
  // access, appear in the org list, or can be switched into.
  status         MembershipStatus @default(ACTIVE)
  userId         String
  organizationId String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId, status])
}

model PublisherMembership {
  id          String        @id @default(cuid())
  role        PublisherRole @default(PUBLISHER_OWNER)
  userId      String
  publisherId String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  publisher Publisher @relation(fields: [publisherId], references: [id])

  @@unique([userId, publisherId])
  @@index([publisherId])
}

model StaffMembership {
  id          String    @id @default(cuid())
  role        StaffRole @default(OPERATIONS)
  userId      String    @unique
  permissions Json      @default("[]") // String array of permission codes e.g. ["FINANCIAL_DATA_DECRYPT"]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Team {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model Publisher {
  id             String        @id @default(cuid())
  name           String
  email          String?
  organizationId String
  tier           PublisherTier @default(NEW)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization         Organization          @relation(fields: [organizationId], references: [id])
  websites             Website[]
  publisherMemberships PublisherMembership[]
  balance              PublisherBalance?
  withdrawals          Withdrawal[]
  payoutMethods        PayoutMethod[]
  settlements          Settlement[]
  marketplaceListings  MarketplaceListing[]
  profile              PublisherProfile?
  transactions         Transaction[]
  activeContexts       ActiveContext[]
  orderReviews         OrderReview[]
  tickets              Ticket[]              @relation("TicketPublisher")

  @@index([organizationId])
}

enum WebsiteVerificationStatus {
  PENDING_VERIFICATION
  VERIFIED
  VERIFICATION_FAILED
  REVOKED
}

enum VerificationMethod {
  DNS_TXT
}

model Website {
  id              String               @id @default(cuid())
  url             String               @unique
  // Normalized hostname (lowercase, www-stripped) — dedupe key; URL
  // uniqueness alone is bypassed by www/trailing-slash variants.
  domain          String?
  name            String?
  category        String?
  language        String?
  country         String?
  metrics         Json?
  isActive        Boolean              @default(true)
  publisherId     String?
  ownershipType   WebsiteOwnershipType @default(PUBLISHER)
  // Phase 6.5: which OPERATIONS staff member manages this site. NULL for
  // PUBLISHER sites (publisher org membership is the source of truth) and
  // for PLATFORM sites that haven't been assigned yet (orders fall back to
  // the shared Ops queue). Set on create when an OPERATIONS staffer adds the
  // site, and admin-mutable via PATCH /admin/websites/:id/assign.
  managedByUserId String?

  // ── Domain ownership verification (DNS TXT) ──
  // Publisher sites start PENDING_VERIFICATION and must prove control via a
  // DNS TXT record before any listing on them can be approved. Platform sites
  // are created VERIFIED (the platform owns them).
  verificationStatus           WebsiteVerificationStatus @default(PENDING_VERIFICATION)
  verificationMethod           VerificationMethod?
  // Token the publisher must currently publish in DNS (next verification cycle).
  verificationToken            String?
  // Token actually proven present in DNS — what the periodic sweep re-checks.
  // Kept separate from verificationToken so rotation never false-revokes a
  // domain whose published TXT still holds the previously-proven secret.
  activeVerifiedToken          String?
  verifiedAt                   DateTime?
  lastVerificationCheckAt      DateTime?
  lastSuccessfulVerificationAt DateTime?
  lastVerificationRequestAt    DateTime?
  verificationCheckCount       Int                       @default(0)
  // Consecutive failed health checks. 3 in a row -> REVOKED (transient-tolerant).
  consecutiveFailures          Int                       @default(0)
  verificationFailureReason    String?
  // Canonical apex domain (protocol/path/www stripped, lowercase, punycode).
  // Unique per non-platform site — one verified domain = one publisher.
  canonicalDomain              String?
  // Internal moderation trust score 0-100 (never exposed publicly).
  trustScore                   Int?
  // Optimistic-lock guard for worker transitions
  verificationVersion          Int                       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  publisher           Publisher?           @relation(fields: [publisherId], references: [id])
  managedBy           User?                @relation("WebsiteManager", fields: [managedByUserId], references: [id])
  orders              Order[]
  orderItems          OrderItem[]
  marketplaceListings MarketplaceListing[]

  @@index([publisherId])
  @@index([isActive])
  @@index([ownershipType])
  @@index([domain])
  @@index([canonicalDomain])
  @@index([verificationToken])
  @@index([verificationStatus])
  @@index([verifiedAt])
  @@index([managedByUserId, ownershipType])
}

model Order {
  id                      String              @id @default(cuid())
  type                    ServiceType
  status                  OrderStatus         @default(DRAFT)
  amount                  Decimal?
  currency                String              @default("USD")
  paymentStatus           PaymentStatus       @default(PENDING)
  title                   String?
  instructions            String?
  targetUrl               String?
  anchorText              String?
  publishedUrl            String?
  publishedAt             DateTime?
  verifiedAt              DateTime?
  verifiedBy              String?
  verifyMethod            String?
  deliveredAt             DateTime?
  revisionCount           Int                 @default(0)
  customerId              String
  assigneeId              String?
  websiteId               String?
  organizationId          String
  campaignId              String?
  idempotencyKey          String?
  version                 Int                 @default(0)
  // Points at the current OrderDeliveryVersion (source of truth for delivery).
  // Legacy publishedUrl/verifiedAt/deliveredAt are denormalized mirrors of it.
  activeDeliveryVersionId String?
  // ── Listing-service snapshot (Phase 1 additive; required in Phase 4) ──
  // Captured at order creation from the chosen MarketplaceListing →
  // ListingService row so that subsequent price/TAT/availability edits on
  // the live listing never alter the contract for in-flight orders. type,
  // amount, websiteId, turnaroundDays are denormalized mirrors of the chosen
  // ListingService at that moment.
  listingId               String?
  listingServiceId        String?
  fulfillmentChannel      FulfillmentChannel?
  turnaroundDays          Int?
  // Phase 6: per-service structured brief. Validated server-side against
  // the @guestpost/shared briefSchemas registry keyed on serviceType. NULL
  // for legacy orders (renderers fall back to title/instructions).
  briefData               Json?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  customer               User                    @relation("OrderCustomer", fields: [customerId], references: [id])
  assignee               User?                   @relation("OrderAssignee", fields: [assigneeId], references: [id])
  website                Website?                @relation(fields: [websiteId], references: [id])
  organization           Organization            @relation(fields: [organizationId], references: [id])
  campaign               Campaign?               @relation(fields: [campaignId], references: [id])
  listing                MarketplaceListing?     @relation(fields: [listingId], references: [id])
  listingService         ListingService?         @relation(fields: [listingServiceId], references: [id])
  contentOrder           ContentOrder?
  revisions              Revision[]
  reports                Report[]
  transactions           Transaction[]
  items                  OrderItem[]
  events                 OrderEvent[]
  settlements            Settlement[]
  dispute                OrderDispute?
  platformRevenue        PlatformRevenue?
  deliveryVersions       OrderDeliveryVersion[]
  fulfillmentAssignments FulfillmentAssignment[]
  fraudFlags             DeliveryFraudFlag[]
  tickets                Ticket[]
  review                 OrderReview?

  // Scoped per organization — a globally unique key let one tenant replay
  // another tenant's key and read their order (cross-tenant leak).
  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, status])
  @@index([customerId, status])
  @@index([assigneeId])
  @@index([websiteId])
  @@index([campaignId])
  @@index([createdAt])
  @@index([listingId])
  @@index([listingServiceId])
  @@index([fulfillmentChannel, status])
}

model Campaign {
  id             String         @id @default(cuid())
  name           String
  description    String?
  status         CampaignStatus @default(ACTIVE)
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  orders       Order[]

  @@index([organizationId])
}

// Service model removed in Phase 7 cleanup — global per-type pricing was the
// pre-marketplace fallback and is unused since the Phase 4 hard switch. See
// migration 20260615120000_phase7_legacy_drop.

model OrderItem {
  id          String      @id @default(cuid())
  orderId     String
  websiteId   String?
  publisherId String?
  targetUrl   String?
  anchorText  String?
  price       Decimal?
  status      OrderStatus @default(PENDING_PAYMENT)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  order        Order         @relation(fields: [orderId], references: [id])
  website      Website?      @relation(fields: [websiteId], references: [id])
  publications Publication[]

  @@index([orderId])
  @@index([publisherId])
  @@index([websiteId])
}

model OrderEvent {
  id        String         @id @default(cuid())
  orderId   String
  eventType OrderEventType
  actorId   String?
  message   String?
  metadata  Json?
  createdAt DateTime       @default(now())

  order Order @relation(fields: [orderId], references: [id])
  actor User? @relation(fields: [actorId], references: [id])

  @@index([orderId, createdAt])
  @@index([actorId])
}

model Publication {
  id                 String             @id @default(cuid())
  orderItemId        String
  publishedUrl       String?
  targetUrl          String?
  anchorText         String?
  publicationDate    DateTime?
  verificationStatus VerificationStatus @default(PENDING)
  verifiedBy         String?
  verifiedAt         DateTime?
  screenshotUrl      String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  orderItem      OrderItem @relation(fields: [orderItemId], references: [id])
  verifiedByUser User?     @relation("PublicationVerifier", fields: [verifiedBy], references: [id])

  @@index([orderItemId])
  @@index([verifiedBy])
  @@index([verificationStatus])
}

model OrderDispute {
  id             String        @id @default(cuid())
  orderId        String        @unique
  order          Order         @relation(fields: [orderId], references: [id])
  raisedBy       String
  reason         String
  status         DisputeStatus @default(OPEN)
  // Order status at dispute open — RESTORE/REJECT resolutions return the
  // order to this exact status, not a hardcoded guess.
  previousStatus OrderStatus?
  resolvedBy     String?
  resolvedAt     DateTime?
  resolution     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Settlement {
  id                 String                @id @default(cuid())
  orderId            String
  publisherId        String
  grossAmount        Decimal
  platformFee        Decimal               @default(0)
  publisherAmount    Decimal
  status             SettlementStatus      @default(PENDING)
  reviewEndsAt       DateTime?
  settledAt          DateTime?
  version            Int                   @default(0)
  // ── Phase 6 reporting snapshots (additive; NULL on legacy rows) ──
  // Captured at settlement creation by joining the order's snapshot. Frozen
  // forever so refunds, audits, and reports can re-derive the contract
  // even after the publisher edits the listing.
  listingServiceId   String?
  serviceType        ServiceType?
  ownerType          WebsiteOwnershipType?
  fulfillmentChannel FulfillmentChannel?
  unitPrice          Decimal?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  order          Order                @relation(fields: [orderId], references: [id])
  publisher      Publisher            @relation(fields: [publisherId], references: [id])
  approvals      SettlementApproval[]
  transactions   Transaction[]
  listingService ListingService?      @relation(fields: [listingServiceId], references: [id])

  // NOTE: a partial unique index "Settlement_orderId_active_key" on (orderId)
  // WHERE status != 'CANCELLED' exists via raw SQL migration — Prisma cannot
  // express partial indexes. Do not remove it when regenerating migrations.
  @@index([orderId])
  @@index([publisherId, status])
  @@index([status])
  @@index([serviceType])
  @@index([fulfillmentChannel])
  @@index([listingServiceId])
}

enum SettlementApprovalType {
  CUSTOMER
  ADMIN
}

model SettlementApproval {
  id           String                 @id @default(cuid())
  settlementId String
  settlement   Settlement             @relation(fields: [settlementId], references: [id])
  type         SettlementApprovalType
  approvedBy   String
  roleAtTime   String
  approvedAt   DateTime               @default(now())

  @@unique([settlementId, type])
  @@index([settlementId])
}

// ── Order delivery: verification, evidence, fulfillment assignment ──────────
// A delivery is not a human "done" claim. It is an immutable versioned record
// (OrderDeliveryVersion) plus platform-captured evidence + snapshot. Settlement
// gates on independent verification, never on the claim alone.

enum FulfillmentAssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  DELIVERED
  CANCELLED
}

enum DeliveryVerificationStatus {
  PENDING
  VERIFIED
  FAILED
  MANUAL_REVIEW
  RETRYING
}

enum DeliveryInterventionStatus {
  NONE
  APPROVED
  REJECTED
  OVERRIDDEN
}

// Platform-owned orders enter the Operations queue. Operations claims/assigns
// and fulfills; identical downstream verification + settlement path as
// publisher inventory (no bypass for platform inventory).
model FulfillmentAssignment {
  id               String                      @id @default(cuid())
  orderId          String
  assignedToUserId String
  assignedByUserId String
  assignedAt       DateTime                    @default(now())
  completedAt      DateTime?
  status           FulfillmentAssignmentStatus @default(ASSIGNED)
  version          Int                         @default(0)
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([assignedToUserId, status])
  @@index([status])
}

// Immutable delivery version. Revisions create NEW versions; nothing is ever
// overwritten or deleted. Order.activeDeliveryVersionId points at the current.
model OrderDeliveryVersion {
  id                        String                     @id @default(cuid())
  orderId                   String
  version                   Int
  publishedUrl              String
  normalizedUrl             String
  articleTitle              String?
  notes                     String?
  screenshotUrl             String?
  submittedByUserId         String
  submittedAt               DateTime                   @default(now())
  verificationStatus        DeliveryVerificationStatus @default(PENDING)
  verificationFailureReason String?
  interventionStatus        DeliveryInterventionStatus @default(NONE)
  supersededByVersion       Int?
  // Optimistic-lock guard for worker/intervention transitions
  verificationVersion       Int                        @default(0)
  createdAt                 DateTime                   @default(now())

  order      Order                          @relation(fields: [orderId], references: [id])
  evidence   DeliveryVerificationEvidence[]
  snapshots  DeliverySnapshot[]
  fraudFlags DeliveryFraudFlag[]

  @@unique([orderId, version])
  @@index([orderId])
  @@index([verificationStatus])
  @@index([normalizedUrl])
}

// Immutable verification evidence — survives disputes + revisions forever.
model DeliveryVerificationEvidence {
  id                 String   @id @default(cuid())
  deliveryVersionId  String
  pageTitle          String?
  metaTitle          String?
  canonicalUrl       String?
  resolvedUrl        String
  httpStatus         Int
  anchorFound        Boolean  @default(false)
  linkFound          Boolean  @default(false)
  targetUrlMatched   Boolean  @default(false)
  verifiedAnchorText String?
  verifiedTargetUrl  String?
  htmlHash           String?
  redirectChain      Json?
  checkedAt          DateTime @default(now())
  createdAt          DateTime @default(now())

  deliveryVersion OrderDeliveryVersion @relation(fields: [deliveryVersionId], references: [id])

  @@index([deliveryVersionId])
}

// Raw HTML + headers stored permanently in object storage (MinIO dev / R2 prod).
model DeliverySnapshot {
  id                  String   @id @default(cuid())
  deliveryVersionId   String
  htmlObjectKey       String
  screenshotObjectKey String?
  responseHeaders     Json?
  createdAt           DateTime @default(now())

  deliveryVersion OrderDeliveryVersion @relation(fields: [deliveryVersionId], references: [id])

  @@index([deliveryVersionId])
}

model DeliveryFraudFlag {
  id                String   @id @default(cuid())
  orderId           String
  deliveryVersionId String
  type              String
  details           Json?
  createdAt         DateTime @default(now())

  order           Order                @relation(fields: [orderId], references: [id])
  deliveryVersion OrderDeliveryVersion @relation(fields: [deliveryVersionId], references: [id])

  @@index([orderId])
  @@index([deliveryVersionId])
  @@index([type])
}

// Per-order review left by the customer after completion. One per order; feeds
// the publisher trust rating (separate from listing-level MarketplaceReview).
model OrderReview {
  id          String   @id @default(cuid())
  orderId     String   @unique
  publisherId String?
  customerId  String
  rating      Int // 1..5
  comment     String?
  createdAt   DateTime @default(now())

  order     Order      @relation(fields: [orderId], references: [id])
  publisher Publisher? @relation(fields: [publisherId], references: [id])

  @@index([publisherId])
  @@index([customerId])
}

model PublisherBalance {
  id                  String   @id @default(cuid())
  publisherId         String   @unique
  pendingBalance      Decimal  @default(0)
  approvedBalance     Decimal  @default(0)
  withdrawableBalance Decimal  @default(0)
  // Owed back to the platform (refund clawback exceeded withdrawable).
  // Netted against future settlement releases before crediting withdrawable.
  debtBalance         Decimal  @default(0)
  lifetimeEarnings    Decimal  @default(0)
  lifetimePaid        Decimal  @default(0)
  version             Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  publisher Publisher @relation(fields: [publisherId], references: [id])
}

model Withdrawal {
  id             String           @id @default(cuid())
  publisherId    String
  amount         Decimal
  method         String           @default("bank_transfer")
  status         WithdrawalStatus @default(PENDING)
  // Tier-based hold: approval is rejected before this timestamp.
  availableAt    DateTime?
  // Client-supplied dedup key — scoped per publisher, never used as PK.
  idempotencyKey String?
  payoutMethodId String?
  payoutBatchId  String?
  approvedBy     String?
  approvedAt     DateTime?
  version        Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  publisher      Publisher         @relation(fields: [publisherId], references: [id])
  approvedByUser User?             @relation("WithdrawalApprover", fields: [approvedBy], references: [id])
  payoutMethod   PayoutMethod?     @relation(fields: [payoutMethodId], references: [id])
  payoutBatch    PayoutBatch?      @relation(fields: [payoutBatchId], references: [id])
  executions     PayoutExecution[]

  @@unique([publisherId, idempotencyKey])
  @@index([publisherId, status])
  @@index([approvedBy])
  @@index([status])
  @@index([payoutMethodId])
  @@index([payoutBatchId])
}

model PayoutMethod {
  id                   String   @id @default(cuid())
  publisherId          String
  type                 String // bank_transfer, paypal, wise
  label                String
  details              Json // AES-256-GCM encrypted via PayoutEncryptionService
  displayDetails       Json? // Non-sensitive display fields (bank name, last4) — unencrypted, safe for list endpoints
  encryptionKeyVersion Int      @default(0)
  isDefault            Boolean  @default(false)
  isActive             Boolean  @default(true)
  version              Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  publisher   Publisher    @relation(fields: [publisherId], references: [id])
  withdrawals Withdrawal[]

  @@index([publisherId])
}

model PayoutProvider {
  id                         String   @id @default(cuid())
  name                       String   @unique // "manual", "wise", "stripe_connect"
  displayName                String
  config                     Json // Provider-specific config (API keys, webhook secrets) — AES-256-GCM encrypted
  configEncryptionKeyVersion Int      @default(0)
  isActive                   Boolean  @default(true)
  version                    Int      @default(0)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  executions PayoutExecution[]

  @@index([isActive])
}

model PayoutExecution {
  id                  String                @id @default(cuid())
  withdrawalId        String
  providerId          String
  status              PayoutExecutionStatus @default(PENDING)
  providerExecutionId String? // Provider's reference ID (transfer ID, payment ID)
  amount              Decimal
  fee                 Decimal               @default(0)
  errorMessage        String?
  providerMetadata    Json?
  idempotencyKey      String?
  version             Int                   @default(0)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  withdrawal Withdrawal     @relation(fields: [withdrawalId], references: [id])
  provider   PayoutProvider @relation(fields: [providerId], references: [id])

  @@unique([withdrawalId, idempotencyKey])
  @@index([withdrawalId, status])
  @@index([providerId, status])
  @@index([status, createdAt])
  @@index([providerExecutionId])
}

model PayoutBatch {
  id              String            @id @default(cuid())
  name            String
  status          PayoutBatchStatus @default(PENDING)
  totalAmount     Decimal           @default(0)
  totalCount      Int               @default(0)
  completedAmount Decimal           @default(0)
  completedCount  Int               @default(0)
  failedCount     Int               @default(0)
  notes           String?
  metadata        Json?
  createdBy       String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  withdrawals Withdrawal[]

  @@index([status, createdAt])
  @@index([createdBy])
}

model ApiKey {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  keyHash        String    @unique
  permissions    Json      @default("[]")
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model ContentOrder {
  id          String             @id @default(cuid())
  title       String
  brief       String?
  status      ContentOrderStatus @default(PENDING)
  deliverable String?
  orderId     String             @unique
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  order Order @relation(fields: [orderId], references: [id])
}

model Revision {
  id        String         @id @default(cuid())
  notes     String?
  files     Json?
  status    RevisionStatus @default(REQUESTED)
  orderId   String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model Report {
  id         String    @id @default(cuid())
  type       String
  data       Json?
  format     String    @default("pdf")
  exportedAt DateTime?
  orderId    String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model PlatformRevenue {
  id                 String                @id @default(cuid())
  orderId            String                @unique
  amount             Decimal
  platformFee        Decimal               @default(0)
  netRevenue         Decimal
  recordedAt         DateTime              @default(now())
  // Set on refund instead of deleting the row — financial records are
  // never destroyed. Revenue queries must filter reversedAt: null.
  reversedAt         DateTime?
  // Phase 6 reporting snapshots — same shape as Settlement.
  listingServiceId   String?
  serviceType        ServiceType?
  ownerType          WebsiteOwnershipType?
  fulfillmentChannel FulfillmentChannel?
  unitPrice          Decimal?
  createdAt          DateTime              @default(now())

  order          Order           @relation(fields: [orderId], references: [id])
  listingService ListingService? @relation(fields: [listingServiceId], references: [id])

  @@index([recordedAt])
  @@index([serviceType])
  @@index([fulfillmentChannel])
  @@index([listingServiceId])
}

model Wallet {
  id               String   @id @default(cuid())
  availableBalance Decimal  @default(0)
  reservedBalance  Decimal  @default(0)
  currency         String   @default("USD")
  organizationId   String?
  userId           String?
  version          Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  transactions Transaction[]

  @@unique([organizationId])
  @@index([userId])
}

enum TransactionType {
  DEPOSIT
  PURCHASE
  REFUND
  WITHDRAWAL
  WITHDRAWAL_REVERSAL
  SETTLEMENT_RELEASE
  SETTLEMENT_CLAWBACK
  DEBT_REPAYMENT
  RESERVATION
  // Chargeback lost at the bank — money left the platform permanently.
  // Included in wallet reconciliation sums (unlike RESERVATION).
  CHARGEBACK
}

model Transaction {
  id           String          @id @default(cuid())
  amount       Decimal
  currency     String          @default("USD")
  type         TransactionType
  reference    String?
  // External provider linkage (e.g. Stripe payment_intent for deposits) —
  // lets chargeback webhooks find the originating deposit + wallet.
  providerRef  String?
  description  String?
  walletId     String?
  orderId      String?
  publisherId  String?
  settlementId String?
  createdAt    DateTime        @default(now())

  wallet     Wallet?     @relation(fields: [walletId], references: [id])
  order      Order?      @relation(fields: [orderId], references: [id])
  publisher  Publisher?  @relation(fields: [publisherId], references: [id])
  settlement Settlement? @relation(fields: [settlementId], references: [id])

  @@unique([reference])
  @@index([walletId])
  @@index([orderId])
  @@index([type])
  @@index([createdAt])
  @@index([publisherId])
  @@index([settlementId])
  @@index([providerRef])
}

model Ticket {
  id                  String              @id @default(cuid())
  subject             String
  description         String?
  status              TicketStatus        @default(OPEN)
  organizationId      String
  userId              String
  // Optional link to the order the ticket is about — lets customers get help
  // straight from an order and gives staff full context.
  orderId             String?
  // Phase 6.5 channel-aware routing. Snapshotted from the linked order at
  // ticket creation; subsequent website/listing edits never re-route an
  // existing ticket (prevents accidental exposure to a new owner).
  //   - PLATFORM channel: assignedToUserId = Website.managedByUserId at the
  //     moment the ticket was opened. NULL falls back to the unassigned-Ops
  //     queue surfaced to every OPERATIONS staffer.
  //   - PUBLISHER channel: assignedPublisherId = Website.publisherId. Reply
  //     access then keys off PublisherMembership rather than a single user.
  fulfillmentChannel  FulfillmentChannel?
  assignedToUserId    String?
  assignedPublisherId String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  organization      Organization    @relation(fields: [organizationId], references: [id])
  user              User            @relation(fields: [userId], references: [id])
  order             Order?          @relation(fields: [orderId], references: [id])
  assignedTo        User?           @relation("TicketAssignee", fields: [assignedToUserId], references: [id])
  assignedPublisher Publisher?      @relation("TicketPublisher", fields: [assignedPublisherId], references: [id])
  messages          TicketMessage[]

  @@index([organizationId, status])
  @@index([userId])
  @@index([status])
  @@index([orderId])
  @@index([assignedToUserId, status])
  @@index([assignedPublisherId, status])
  @@index([fulfillmentChannel, status])
}

// Phase 6.6: every ticket message carries a visibility scope. PUBLIC is the
// historical default and what every existing row gets at migration time;
// INTERNAL is staff-only — invisible to the ticket's customer and to any
// publisher member, and used by Finance (who is read-only on PLATFORM tickets)
// + Admin + Ops as an escape valve to coordinate without writing to the
// customer-facing thread.
enum TicketMessageVisibility {
  PUBLIC
  INTERNAL
}

// Phase 6.6.1: which "hat" the author was wearing at write time. Snapshotted
// onto every TicketMessage row — never derived dynamically from current
// memberships, so historical audit trails remain accurate even after a
// staffer's role changes. This is the same forensic discipline as
// SettlementApproval.roleAtTime.
//
// Used for:
//   - Dispute / refund / settlement investigations ("who said what in what
//     capacity?")
//   - Staff QA reviews ("Finance posted on a Platform ticket — that's the
//     internal-note escape valve in action")
//   - Audit log enrichment (TICKET_MESSAGE_ADDED metadata carries this so
//     reports can group by role without a join through StaffMembership)
enum TicketParticipantRole {
  CUSTOMER
  PUBLISHER
  OPS
  ADMIN
  FINANCE
}

// Phase 6.6.1: orthogonal to visibility. MESSAGE = human reply (default);
// INTERNAL_NOTE = staff-only note (visibility is always INTERNAL); SYSTEM_EVENT
// = machine-emitted thread entry (reassigned, status changed, auto-resolved).
// SYSTEM_EVENT is schema-ready but not yet emitted by any service path; it
// lets the UI render system entries distinctly from human messages without
// requiring a parallel "events" table.
enum TicketMessageType {
  MESSAGE
  INTERNAL_NOTE
  SYSTEM_EVENT
}

model TicketMessage {
  id              String                  @id @default(cuid())
  content         String
  files           Json?
  visibility      TicketMessageVisibility @default(PUBLIC)
  // Phase 6.6.1: role-at-write-time + message classification snapshot.
  participantRole TicketParticipantRole
  messageType     TicketMessageType       @default(MESSAGE)
  // Phase 6.6.2: full actor context snapshot — uncollapsed companion to
  // participantRole. Captures the raw schema-level roles the actor held at
  // write time so investigations can answer "was this CUSTOMER an OWNER or
  // MEMBER?" / "was this STAFF SUPER_ADMIN or FINANCE?" without joining
  // through StaffMembership/Membership (which mutate over time and would
  // lie about historical authority).
  //
  // Shape (open — future fields like permissions[] can be added without a
  // migration):
  //   { kind: "CUSTOMER" | "PUBLISHER" | "STAFF",
  //     staffRole: "SUPER_ADMIN" | "OPERATIONS" | "FINANCE" | null,
  //     organizationRole: "OWNER" | "MEMBER" | null,
  //     publisherRole: "PUBLISHER_OWNER" | "PUBLISHER_MEMBER" | null }
  //
  // Nullable for backward compat — pre-migration rows have NULL.
  actorSnapshot   Json?
  userId          String
  ticketId        String
  createdAt       DateTime                @default(now())

  user   User   @relation(fields: [userId], references: [id])
  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
  // Composite covers the "show me the customer-visible thread" read path
  // (ticketId + visibility=PUBLIC) without a separate scan.
  @@index([ticketId, visibility])
  // Audit / investigation filter: "all FINANCE messages on this ticket",
  // "all OPS replies in this window".
  @@index([ticketId, participantRole])
}

model Notification {
  id             String   @id @default(cuid())
  type           String
  message        String
  read           Boolean  @default(false)
  userId         String
  // Nullable: staff/system notifications (e.g. chargeback alerts) have no org.
  organizationId String?
  // Phase 7.4 (audit #12) — when writers supply a deterministic key (e.g.
  // `recon:walletDrift:wallet-abc:user-xyz:2026-06-16`), the unique constraint
  // below catches BullMQ-retry duplicates. NULL = no dedup applies (legacy
  // path; the partial unique index below excludes NULL rows, so multiple
  // NULLs coexist freely). Builders live in packages/shared/src/notification-dedup-keys.ts.
  dedupKey       String?  @db.VarChar(256)
  createdAt      DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([userId, read, createdAt])
  @@index([organizationId, createdAt])
  @@index([read])
  // Partial unique — see migration 20260616100000_phase74_notification_dedup.
  // Prisma doesn't model partial uniques directly; this @@unique mirrors the
  // SQL constraint name. NULL dedupKey rows are exempt.
  @@unique([userId, dedupKey], map: "Notification_userId_dedupKey_key")
}

model AuditLog {
  id             String   @id @default(cuid())
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  // Nullable: system/webhook actions and platform-scope actions have no
  // real user/org. Sentinel strings ("SYSTEM") violated the FK and were
  // silently dropped by the audit service — never reintroduce them.
  userId         String?
  organizationId String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  user         User?         @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId, action, createdAt])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([action])
}

// =============================================================================
// MARKETPLACE MODELS
// =============================================================================

// Phase 7: enum ListingType removed. The deprecated MarketplaceListing.type
// column it backed is gone; service offerings are now expressed as
// ServiceType values on ListingService rows.

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  PAUSED
  ARCHIVED
}

enum ListingFulfillmentType {
  INTERNAL
  PUBLISHER
  HYBRID
}

model MarketplaceCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  parentId    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   MarketplaceCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children MarketplaceCategory[] @relation("CategoryHierarchy")
  listings MarketplaceListing[]

  @@index([slug])
  @@index([parentId])
}

model MarketplaceTag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  listings MarketplaceListingTag[]
}

model MarketplaceListing {
  id               String                 @id @default(cuid())
  title            String
  slug             String                 @unique
  description      String
  shortDescription String?
  // Phase 7 cleanup: `type` / `price` / `turnaroundDays` / `revisionRounds`
  // / `warrantyDays` were dropped — per-service data lives on the
  // ListingService child table. See migration 20260615130000_phase7_listing_columns.
  status           ListingStatus          @default(DRAFT)
  fulfillmentType  ListingFulfillmentType @default(PUBLISHER)
  // Authoritative ownership at the listing layer. Backfilled in Phase 1 from
  // (publisherId IS NOT NULL ? PUBLISHER : PLATFORM). Routing, attribution
  // ("Listed by GuestPost.cc"), and approval-queue gating read this column.
  ownerType        WebsiteOwnershipType   @default(PUBLISHER)

  // Pricing — listing-level columns dropped in Phase 7. Reads use priceFrom
  // (computed from AVAILABLE ListingService rows).
  currency  String   @default("USD")
  priceType String   @default("fixed") // fixed, starting_at, range, negotiable
  minPrice  Decimal?
  maxPrice  Decimal?

  // Metrics
  domainRating     Int?
  domainAuthority  Int?
  traffic          Int?
  referringDomains Int?
  spamScore        Int?

  // Location & Language
  country   String?
  language  String?
  countries String[] @default([])
  languages String[] @default([])

  // Features
  featured     Boolean @default(false)
  verified     Boolean @default(false)
  // allowGuestPost / allowNicheEdit removed in Phase 5 cleanup — multi-service
  // listings encode service availability via the ListingService child table.
  doFollowOnly Boolean @default(false)

  // URLs
  websiteUrl String?
  sampleUrl  String?
  signupUrl  String?

  // Metrics data (JSON for flexibility)
  metricsData Json?
  trafficData Json?
  semrushData Json?

  // Publisher reference (for PUBLISHER type)
  publisherId String?
  websiteId   String?

  // Organization reference (for INTERNAL and publisher listings)
  organizationId String?

  // Timestamps
  publishedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  publisher    Publisher?           @relation(fields: [publisherId], references: [id])
  website      Website?             @relation(fields: [websiteId], references: [id])
  organization Organization?        @relation(fields: [organizationId], references: [id])
  category     MarketplaceCategory? @relation(fields: [categoryId], references: [id])

  tags       MarketplaceListingTag[]
  images     MarketplaceListingImage[]
  // pricingTiers removed in Phase 5 — replaced by per-service prices on the
  // ListingService child table.
  reviews    MarketplaceReview[]
  favorites  MarketplaceFavorite[]
  savedLists MarketplaceSavedListItem[]
  views      MarketplaceListingView[]
  clicks     MarketplaceListingClick[]
  services   ListingService[]
  orders     Order[]

  categoryId String?

  @@index([slug])
  // Phase 7: @@index([type]) dropped alongside MarketplaceListing.type.
  @@index([status])
  @@index([publisherId])
  @@index([categoryId])
  @@index([featured])
  @@index([createdAt])
  // Phase 7: @@index([price]) dropped alongside MarketplaceListing.price.
  // Sorting/filtering by price now hits the ListingService(availability,
  // serviceType, price) composite index.
  @@index([ownerType, status])
}

// A purchasable service offering on a MarketplaceListing. One listing can
// expose N service rows — e.g. GUEST_POST at $150 / 7d AND NICHE_EDIT at $80
// / 3d on the same website — replacing the previous "one listing = one
// service" model. Order.create snapshots the chosen row's serviceType,
// price, currency, turnaroundDays onto the order, so later edits to this
// row never change the contract for in-flight orders.
model ListingService {
  id                  String              @id @default(cuid())
  listingId           String
  serviceType         ServiceType
  price               Decimal
  currency            String              @default("USD")
  turnaroundDays      Int
  revisionRounds      Int                 @default(2)
  warrantyDays        Int?
  // JSON, free-form publisher-defined requirements (anchorPolicy,
  // niches, min wordCount, do-follow only, content guidelines, ...).
  requirements        Json?
  // JSON, fulfillment configuration (autoAccept, internalSlaHours,
  // requiresBrief, ...). Read by routing services; never exposed publicly.
  fulfillmentSettings Json?
  availability        ServiceAvailability @default(AVAILABLE)
  // Optimistic-lock guard for concurrent edits + Order.create race.
  version             Int                 @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  listing          MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  orders           Order[]
  settlements      Settlement[]
  platformRevenues PlatformRevenue[]

  // A given service type can appear at most once per listing.
  @@unique([listingId, serviceType])
  @@index([listingId])
  @@index([serviceType, availability])
  @@index([availability])
  // Phase 6 search hot-path indexes for `services.some({…})` filters.
  @@index([availability, serviceType, price])
  @@index([availability, turnaroundDays])
}

model MarketplaceListingTag {
  listingId String
  tagId     String

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tag     MarketplaceTag     @relation(fields: [tagId], references: [id])

  @@id([listingId, tagId])
}

model MarketplaceListingImage {
  id        String   @id @default(cuid())
  listingId String
  url       String
  alt       String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

// MarketplacePricingTier removed in Phase 5 — fully replaced by per-service
// pricing on ListingService rows. See migration 20260614040000_phase5_cleanup.

model MarketplaceReview {
  id          String    @id @default(cuid())
  listingId   String
  userId      String
  rating      Int
  title       String?
  content     String
  response    String?
  respondedAt DateTime?
  status      String    @default("APPROVED") // APPROVED, PENDING, SPAM, FLAGGED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User               @relation(fields: [userId], references: [id])

  @@index([listingId])
  @@index([userId])
}

model MarketplaceFavorite {
  id          String       @id @default(cuid())
  userId      String
  listingId   String
  // NULL = "favorite the whole listing" (legacy semantics). Non-NULL = scoped
  // to a specific service on the listing — used by the WAITLIST notify-me
  // CTA. When a ListingService flips WAITLIST -> AVAILABLE, a worker fans out
  // to favorites where (listingId = X AND serviceType = Y OR serviceType IS NULL).
  serviceType ServiceType?
  createdAt   DateTime     @default(now())

  user    User               @relation(fields: [userId], references: [id])
  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId, serviceType])
  @@index([userId])
  @@index([listingId])
  @@index([listingId, serviceType])
}

model MarketplaceSavedList {
  id        String   @id @default(cuid())
  userId    String
  name      String
  slug      String
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items MarketplaceSavedListItem[]

  @@unique([userId, slug])
  @@index([userId])
}

model MarketplaceSavedListItem {
  id        String   @id @default(cuid())
  listId    String
  listingId String
  note      String?
  addedAt   DateTime @default(now())

  list    MarketplaceSavedList @relation(fields: [listId], references: [id], onDelete: Cascade)
  listing MarketplaceListing   @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listId, listingId])
  @@index([listingId])
}

model MarketplaceListingView {
  id        String   @id @default(cuid())
  listingId String
  userId    String?
  sessionId String?
  ipAddress String?
  userAgent String?
  referrer  String?
  createdAt DateTime @default(now())

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([createdAt])
  @@index([userId])
}

model MarketplaceListingClick {
  id          String       @id @default(cuid())
  listingId   String
  userId      String?
  sessionId   String?
  ipAddress   String?
  action      String       @default("view") // view, click, cta_click, favorite, share
  // Phase 6: which service the user picked at click-time. NULL on listing-level
  // events (`view`, `favorite`, `share`) and on legacy rows.
  serviceType ServiceType?
  metadata    Json?
  createdAt   DateTime     @default(now())

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([createdAt])
  @@index([action])
  @@index([serviceType])
}

model MarketplaceSearchHistory {
  id          String       @id @default(cuid())
  userId      String?
  query       String
  filters     Json?
  resultCount Int?
  clickedId   String?
  // Phase 6: which service the user filtered for. Powers serviceType-aware
  // recommendation training. NULL on legacy rows or untyped searches.
  serviceType ServiceType?
  createdAt   DateTime     @default(now())

  @@index([userId])
  @@index([query])
  @@index([serviceType])
}

// AI Recommendations
model MarketplaceRecommendation {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  type      String // similar, recommended, frequently_bought, trending, because_you_viewed
  score     Float
  reason    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([listingId])
  @@index([type])
}

// Publisher Profiles for Marketplace
model PublisherProfile {
  id             String   @id @default(cuid())
  publisherId    String   @unique
  bio            String?
  stats          Json? // aggregated stats
  responseTime   Int? // avg response time in hours
  completionRate Float? // order completion rate
  rating         Float?
  // Internal publisher trust score 0-100 (folds in reviews, link uptime,
  // disputes, refunds, completion). Drives the publisher tier.
  trustScore     Int?
  totalReviews   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  publisher Publisher @relation(fields: [publisherId], references: [id])
}

// Fraud Detection
model MarketplaceFlag {
  id         String    @id @default(cuid())
  type       String // duplicate_domain, fake_traffic, spam_reviews, suspicious_pattern, mass_listing
  severity   String // low, medium, high, critical
  status     String    @default("OPEN") // OPEN, REVIEWING, RESOLVED, DISMISSED
  data       Json?
  resolvedBy String?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([type])
  @@index([status])
  @@index([severity])
}

// Fulfillment Rules
model ListingFulfillmentRule {
  id        String   @id @default(cuid())
  listingId String
  type      String // auto_assign, manual_review, price_threshold
  config    Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
}

// Singleton platform configuration (one row). Values resolved at runtime;
// historical settlements retain the rate captured at creation time.
model PlatformSettings {
  id             String   @id @default(cuid())
  platformFeePct Decimal  @default(20)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
