enum SettlementStatus {
  PENDING
  UNDER_REVIEW
  CUSTOMER_APPROVED
  ADMIN_APPROVED
  RELEASED
  CANCELLED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
  FAILED
  REVERSED
}

enum PayoutExecutionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum PublisherProviderAccountStatus {
  PENDING_ONBOARDING
  RESTRICTED
  ENABLED
  DISABLED
}

// Durable inbox state for cryptographically verified payout-provider events.
// Webhook delivery is acknowledged only after one of these rows commits, so
// Redis availability is never part of the financial acknowledgement boundary.
enum PayoutWebhookEventStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}

enum PayoutBatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  PARTIALLY_COMPLETED
  FAILED
}

enum PublisherTier {
  NEW
  TRUSTED
  VERIFIED
}

// Marketplace listing-service availability. WAITLIST is orderable=false but
// favoritable (MarketplaceFavorite.serviceType captures interest); a worker
// notifies interested users when the row flips to AVAILABLE.
enum ServiceAvailability {
  AVAILABLE
  PAUSED
  WAITLIST
}

// Snapshotted onto Order at creation. Downstream routing (publisher inbox vs
// internal Ops queue, settlement vs PlatformRevenue) keys off this column,
// never re-derives from Website.ownershipType — which can change after the
// order exists.
enum FulfillmentChannel {
  PUBLISHER
  PLATFORM
}

enum VerificationStatus {
  PENDING
  VERIFIED
  FAILED
  DISPUTED
}

enum DeliveryVerificationMethod {
  AUTO
  MANUAL_ADMIN
  CUSTOMER_MANUAL
}

enum DeliveryAcceptedMethod {
  CUSTOMER
  AUTO_TIMEOUT
}

enum VerificationOverrideReason {
  CRAWLER_BLOCKED
  ROBOTS_TXT
  LOGIN_REQUIRED
  JS_RENDERING
  TEMPORARY_FAILURE
  OTHER
}

enum SettlementReleasePolicy {
  AUTO
  MANUAL
}

enum IntegrationOwnerType {
  PUBLISHER
  PLATFORM
}

enum IntegrationProvider {
  GOOGLE_SEARCH_CONSOLE
  GOOGLE_ANALYTICS
  BING_WEBMASTER
}

enum IntegrationStatus {
  PENDING
  DISCOVERING
  ACTIVE
  TOKEN_EXPIRED
  REAUTH_REQUIRED
  DISCONNECTED
  ERROR
}

enum WebsiteIntegrationStatus {
  CONNECTED
  SYNCING
  OUT_OF_SYNC
  INACCESSIBLE
  REMOVED
  DISABLED
}

enum IntegrationSyncStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum IntegrationSyncTrigger {
  MANUAL
  SCHEDULED
  OAUTH
}

model User {
  id                String                   @id @default(cuid())
  email             String                   @unique
  emailVerified     Boolean                  @default(false)
  name              String?
  image             String?
  userType          UserType                 @default(CUSTOMER)
  role              UserRole                 @default(SEO_SPECIALIST)
  banned            Boolean                  @default(false)
  banReason         String?
  banReasonCode     AccountSuspensionReason?
  banExpires        DateTime?
  suspendedAt       DateTime?
  suspendedByUserId String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  memberships                   Membership[]
  publisherMemberships          PublisherMembership[]
  staffMemberships              StaffMembership[]
  ownedOrders                   Order[]                @relation("OrderCustomer")
  assignedOrders                Order[]                @relation("OrderAssignee")
  orderEvents                   OrderEvent[]
  publications                  Publication[]          @relation("PublicationVerifier")
  approvedWithdrawals           Withdrawal[]           @relation("WithdrawalApprover")
  adminVerifiedDeliveryVersions OrderDeliveryVersion[] @relation("AdminVerifiedVersion")
  tickets                       Ticket[]
  messages                      TicketMessage[]
  notifications                 Notification[]
  auditLogs                     AuditLog[]
  sessions                      Session[]
  accounts                      Account[]
  marketplaceReviews            MarketplaceReview[]
  marketplaceFavorites          MarketplaceFavorite[]
  activeContext                 ActiveContext?
  managedWebsites               Website[]              @relation("WebsiteManager")
  assignedTickets               Ticket[]               @relation("TicketAssignee")
  legalAcceptances              LegalAcceptance[]
  suspendedBy                   User?                  @relation("UserSuspensionsIssued", fields: [suspendedByUserId], references: [id], onDelete: SetNull)
  suspensionsIssued             User[]                 @relation("UserSuspensionsIssued")
  websiteImportBatches          WebsiteImportBatch[]

  @@index([userType, banned])
  @@index([suspendedByUserId])
}

model LegalAcceptance {
  id              String   @id @default(cuid())
  userId          String
  documentType    String
  documentVersion String
  acceptedAt      DateTime @default(now())
  method          String
  audience        UserType
  ipAddress       String?
  userAgent       String?
  requestId       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, documentType, documentVersion])
  @@index([acceptedAt])
  @@index([audience, acceptedAt])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

model ActiveContext {
  id                   String  @id @default(cuid())
  userId               String  @unique
  activeOrganizationId String?
  activePublisherId    String?

  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganization Organization? @relation(fields: [activeOrganizationId], references: [id], onDelete: SetNull)
  activePublisher    Publisher?    @relation(fields: [activePublisherId], references: [id], onDelete: SetNull)

  @@index([activeOrganizationId])
  @@index([activePublisherId])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships          Membership[]
  teams                Team[]
  publishers           Publisher[]
  campaigns            Campaign[]
  wallets              Wallet[]
  orders               Order[]
  tickets              Ticket[]
  notifications        Notification[]
  auditLogs            AuditLog[]
  apiKeys              ApiKey[]
  marketplaceListings  MarketplaceListing[]
  activeContexts       ActiveContext[]
  depositAttempts      DepositAttempt[]
  websiteImportBatches WebsiteImportBatch[]
}

enum MembershipStatus {
  PENDING
  ACTIVE
}

model Membership {
  id             String           @id @default(cuid())
  role           CustomerRole     @default(MEMBER)
  // PENDING until the invited user accepts. Only ACTIVE memberships grant
  // access, appear in the org list, or can be switched into.
  status         MembershipStatus @default(ACTIVE)
  userId         String
  organizationId String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId, status])
}

model PublisherMembership {
  id          String        @id @default(cuid())
  role        PublisherRole @default(PUBLISHER_OWNER)
  userId      String
  publisherId String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  publisher Publisher @relation(fields: [publisherId], references: [id])

  @@unique([userId, publisherId])
  @@index([publisherId])
}

model StaffMembership {
  id          String    @id @default(cuid())
  role        StaffRole @default(OPERATIONS)
  userId      String    @unique
  permissions Json      @default("[]") // String array of permission codes e.g. ["FINANCIAL_DATA_DECRYPT"]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Team {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model Publisher {
  id             String        @id @default(cuid())
  name           String
  email          String?
  organizationId String
  tier           PublisherTier @default(NEW)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization         Organization               @relation(fields: [organizationId], references: [id])
  websites             Website[]
  publisherMemberships PublisherMembership[]
  balance              PublisherBalance?
  withdrawals          Withdrawal[]
  payoutMethods        PayoutMethod[]
  settlements          Settlement[]
  marketplaceListings  MarketplaceListing[]
  profile              PublisherProfile?
  transactions         Transaction[]
  activeContexts       ActiveContext[]
  orderReviews         OrderReview[]
  tickets              Ticket[]                   @relation("TicketPublisher")
  providerAccounts     PublisherProviderAccount[]
  websiteImportBatches WebsiteImportBatch[]

  @@index([organizationId])
}

