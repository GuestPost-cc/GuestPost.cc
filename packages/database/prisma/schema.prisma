model Website {
  id              String               @id @default(cuid())
  url             String               @unique
  // Normalized hostname (lowercase, www-stripped) — dedupe key; URL
  // uniqueness alone is bypassed by www/trailing-slash variants.
  domain          String?
  name            String?
  category        String?
  language        String?
  country         String?
  metrics         Json?
  isActive        Boolean              @default(true)
  publisherId     String?
  ownershipType   WebsiteOwnershipType @default(PUBLISHER)
  // Phase 6.5: which OPERATIONS staff member manages this site. NULL for
  // PUBLISHER sites (publisher org membership is the source of truth) and
  // for PLATFORM sites that haven't been assigned yet (orders fall back to
  // the shared Ops queue). Set on create when an OPERATIONS staffer adds the
  // site, and admin-mutable via PATCH /admin/websites/:id/assign.
  managedByUserId String?

  // ── Domain ownership verification (DNS TXT) ──
  // Publisher sites start PENDING_VERIFICATION and must prove control via a
  // DNS TXT record before any listing on them can be approved. Platform sites
  // are created VERIFIED (the platform owns them).
  verificationStatus            WebsiteVerificationStatus @default(PENDING_VERIFICATION)
  verificationMethod            VerificationMethod?
  // Token the publisher must currently publish in DNS (next verification cycle).
  verificationToken             String?
  // Token actually proven present in DNS — what the periodic sweep re-checks.
  // Kept separate from verificationToken so rotation never false-revokes a
  // domain whose published TXT still holds the previously-proven secret.
  activeVerifiedToken           String?
  verifiedAt                    DateTime?
  lastVerificationCheckAt       DateTime?
  lastSuccessfulVerificationAt  DateTime?
  lastVerificationRequestAt     DateTime?
  verificationCheckCount        Int                       @default(0)
  // Consecutive failed health checks. 3 in a row -> REVOKED (transient-tolerant).
  consecutiveFailures           Int                       @default(0)
  verificationFailureReason     String?
  // Break-glass verification never pretends that DNS proof occurred. The
  // expiry makes the override temporary unless a later real TXT check
  // replaces it.
  verificationOverrideExpiresAt DateTime?
  verificationOverrideReason    String?
  verifiedByUserId              String?
  // Canonical apex domain (protocol/path/www stripped, lowercase, punycode).
  // Unique across publisher and platform inventory. This is the durable
  // domain identity used to ensure one site/listing family per domain.
  canonicalDomain               String?
  // Internal moderation trust score 0-100 (never exposed publicly).
  trustScore                    Int?
  // Optimistic-lock guard for worker transitions
  verificationVersion           Int                       @default(0)
  importBatchId                 String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  publisher           Publisher?           @relation(fields: [publisherId], references: [id])
  managedBy           User?                @relation("WebsiteManager", fields: [managedByUserId], references: [id])
  orders              Order[]
  orderItems          OrderItem[]
  marketplaceListings MarketplaceListing[]
  websiteIntegrations WebsiteIntegration[]
  metricsHistory      WebsiteMetric[]
  importBatch         WebsiteImportBatch?  @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  @@index([publisherId])
  @@index([isActive])
  @@index([ownershipType])
  @@index([domain])
  @@index([canonicalDomain])
  @@index([verificationToken])
  @@index([verificationStatus])
  @@index([verifiedAt])
  @@index([managedByUserId, ownershipType])
  @@index([importBatchId])
  @@index([verificationOverrideExpiresAt])
}

// Canonical current value for each source-specific website metric. Provider
// payloads are normalized before persistence; raw responses never enter the
// marketplace read model. WebsiteMetricRevision retains every replacement.
model WebsiteMetric {
  id              String                @id @default(cuid())
  websiteId       String
  key             WebsiteMetricKey
  provider        WebsiteMetricProvider
  source          WebsiteMetricSource
  status          WebsiteMetricStatus   @default(CURRENT)
  value           Decimal               @db.Decimal(20, 4)
  measuredAt      DateTime
  collectedAt     DateTime              @default(now())
  expiresAt       DateTime?
  enteredByUserId String?
  importBatchId   String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  website   Website                 @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  revisions WebsiteMetricRevision[]

  @@unique([websiteId, key])
  @@index([key, value])
  @@index([source, status])
  @@index([expiresAt])
  @@index([importBatchId])
}

model WebsiteMetricRevision {
  id              String                @id @default(cuid())
  metricId        String
  websiteId       String
  key             WebsiteMetricKey
  provider        WebsiteMetricProvider
  source          WebsiteMetricSource
  status          WebsiteMetricStatus
  value           Decimal               @db.Decimal(20, 4)
  measuredAt      DateTime
  collectedAt     DateTime
  expiresAt       DateTime?
  enteredByUserId String?
  importBatchId   String?
  metadata        Json?
  recordedAt      DateTime              @default(now())

  metric WebsiteMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)

  @@index([metricId, recordedAt])
  @@index([websiteId, key, recordedAt])
}

model WebsiteImportBatch {
  id             String              @id @default(cuid())
  publisherId    String
  organizationId String
  actorUserId    String
  idempotencyKey String?
  fileName       String
  fileHash       String
  status         WebsiteImportStatus @default(PREVIEWED)
  totalRows      Int                 @default(0)
  readyRows      Int                 @default(0)
  warningRows    Int                 @default(0)
  errorRows      Int                 @default(0)
  createdRows    Int                 @default(0)
  skippedRows    Int                 @default(0)
  failedRows     Int                 @default(0)
  committedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  publisher    Publisher          @relation(fields: [publisherId], references: [id], onDelete: Restrict)
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  actor        User               @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  rows         WebsiteImportRow[]
  websites     Website[]

  @@unique([actorUserId, idempotencyKey])
  @@index([publisherId, createdAt])
  @@index([status, createdAt])
  @@index([fileHash])
}

model WebsiteImportRow {
  id              String                 @id @default(cuid())
  batchId         String
  rowNumber       Int
  canonicalDomain String?
  status          WebsiteImportRowStatus
  normalizedData  Json?
  errors          String[]               @default([])
  warnings        String[]               @default([])
  websiteId       String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  batch WebsiteImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, rowNumber])
  @@index([batchId, status])
  @@index([canonicalDomain])
  @@index([websiteId])
}

model Order {
  id                      String                      @id @default(cuid())
  type                    ServiceType
  status                  OrderStatus                 @default(DRAFT)
  amount                  Decimal?
  currency                String                      @default("USD")
  paymentStatus           PaymentStatus               @default(PENDING)
  title                   String?
  instructions            String?
  targetUrl               String?
  anchorText              String?
  publishedUrl            String?
  publishedAt             DateTime?
  verifiedAt              DateTime?
  verifiedBy              String?
  verifyMethod            DeliveryVerificationMethod?
  autoAcceptAt            DateTime?
  deliveryAcceptedMethod  DeliveryAcceptedMethod?
  deliveredAt             DateTime?
  revisionCount           Int                         @default(0)
  customerId              String
  assigneeId              String?
  websiteId               String?
  organizationId          String
  campaignId              String?
  idempotencyKey          String?
  version                 Int                         @default(0)
  // Points at the current OrderDeliveryVersion (source of truth for delivery).
  // Legacy publishedUrl/verifiedAt/deliveredAt are denormalized mirrors of it.
  activeDeliveryVersionId String?                     @unique
  // ── Listing-service snapshot (Phase 1 additive; required in Phase 4) ──
  // Captured at order creation from the chosen MarketplaceListing →
  // ListingService row so that subsequent price/TAT/availability edits on
  // the live listing never alter the contract for in-flight orders. type,
  // amount, websiteId, turnaroundDays are denormalized mirrors of the chosen
  // ListingService at that moment.
  listingId               String?
  listingServiceId        String?
  fulfillmentChannel      FulfillmentChannel?
  turnaroundDays          Int?
  warrantyDays            Int?
  submittedAt             DateTime?
  acceptedAt              DateTime?
  fulfillmentDueAt        DateTime?
  warrantyEndsAt          DateTime?
  refundResponsibility    CancellationResponsibility?
  // Phase 6: per-service structured brief. Validated server-side against
  // the @guestpost/shared briefSchemas registry keyed on serviceType. NULL
  // for legacy orders (renderers fall back to title/instructions).
  briefData               Json?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  customer               User                       @relation("OrderCustomer", fields: [customerId], references: [id])
  assignee               User?                      @relation("OrderAssignee", fields: [assigneeId], references: [id])
  website                Website?                   @relation(fields: [websiteId], references: [id])
  activeDeliveryVersion  OrderDeliveryVersion?      @relation("ActiveOrderDeliveryVersion", fields: [activeDeliveryVersionId], references: [id])
  organization           Organization               @relation(fields: [organizationId], references: [id])
  campaign               Campaign?                  @relation(fields: [campaignId], references: [id])
  listing                MarketplaceListing?        @relation(fields: [listingId], references: [id])
  listingService         ListingService?            @relation(fields: [listingServiceId], references: [id])
  contentOrder           ContentOrder?
  articleVersions        OrderArticleVersion[]
  revisions              Revision[]
  reports                Report[]
  transactions           Transaction[]
  items                  OrderItem[]
  events                 OrderEvent[]
  settlements            Settlement[]
  dispute                OrderDispute?
  platformRevenue        PlatformRevenue?
  deliveryVersions       OrderDeliveryVersion[]     @relation("OrderDeliveryVersions")
  fulfillmentAssignments FulfillmentAssignment[]
  fraudFlags             DeliveryFraudFlag[]
  tickets                Ticket[]
  review                 OrderReview?
  cancellationRequests   OrderCancellationRequest[]
  withdrawalAllocations  WithdrawalAllocation[]

  // Scoped per organization — a globally unique key let one tenant replay
  // another tenant's key and read their order (cross-tenant leak).
  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, status])
  @@index([customerId, status])
  @@index([assigneeId])
  @@index([websiteId])
  @@index([campaignId])
  @@index([createdAt])
  @@index([listingId])
  @@index([listingServiceId])
  @@index([fulfillmentChannel, status])
}

model Campaign {
  id             String         @id @default(cuid())
  name           String
  description    String?
  status         CampaignStatus @default(ACTIVE)
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  orders       Order[]

  @@index([organizationId])
}

// Service model removed in Phase 7 cleanup — global per-type pricing was the
// pre-marketplace fallback and is unused since the Phase 4 hard switch. See
// migration 20260615120000_phase7_legacy_drop.

model OrderItem {
  id          String      @id @default(cuid())
  orderId     String
  websiteId   String?
  publisherId String?
  targetUrl   String?
  anchorText  String?
  price       Decimal?
  status      OrderStatus @default(PENDING_PAYMENT)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  order        Order         @relation(fields: [orderId], references: [id])
  website      Website?      @relation(fields: [websiteId], references: [id])
  publications Publication[]

  @@index([orderId])
  @@index([publisherId])
  @@index([websiteId])
}

model OrderEvent {
  id        String         @id @default(cuid())
  orderId   String
  eventType OrderEventType
  actorId   String?
  message   String?
  metadata  Json?
  createdAt DateTime       @default(now())

  order Order @relation(fields: [orderId], references: [id])
  actor User? @relation(fields: [actorId], references: [id])

  @@index([orderId, createdAt])
  @@index([actorId])
}

model Publication {
  id                 String             @id @default(cuid())
  orderItemId        String
  publishedUrl       String?
  targetUrl          String?
  anchorText         String?
  publicationDate    DateTime?
  verificationStatus VerificationStatus @default(PENDING)
  verifiedBy         String?
  verifiedAt         DateTime?
  screenshotUrl      String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  orderItem      OrderItem @relation(fields: [orderItemId], references: [id])
  verifiedByUser User?     @relation("PublicationVerifier", fields: [verifiedBy], references: [id])

  @@index([orderItemId])
  @@index([verifiedBy])
  @@index([verificationStatus])
}

model OrderDispute {
  id             String        @id @default(cuid())
  orderId        String        @unique
  order          Order         @relation(fields: [orderId], references: [id])
  raisedBy       String
  reason         String
  status         DisputeStatus @default(OPEN)
  // Order status at dispute open — RESTORE/REJECT resolutions return the
  // order to this exact status, not a hardcoded guess.
  previousStatus OrderStatus?
  resolvedBy     String?
  resolvedAt     DateTime?
  resolution     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// Structured, auditable cancellation case. Financial resolution is deliberately
// separated from the operational review: a reviewer can recommend a refund,
// but FINANCE must approve it before money moves.
model OrderCancellationRequest {
  id                      String                     @id @default(cuid())
  orderId                 String
  requestedByUserId       String?
  requesterType           CancellationRequesterType
  actorSnapshot           Json?
  reasonCode              CancellationReasonCode
  note                    String?
  status                  CancellationRequestStatus  @default(REQUESTED)
  previousOrderStatus     OrderStatus
  fulfillmentChannel      FulfillmentChannel
  responsibility          CancellationResponsibility @default(UNDETERMINED)
  requestedResolution     CancellationResolution     @default(FULL_REFUND)
  responseDeadlineAt      DateTime?
  respondedByUserId       String?
  responseNote            String?
  reviewedByUserId        String?
  financeApprovedByUserId String?
  resolution              CancellationResolution?
  resolutionReason        String?
  refundTransactionId     String?
  idempotencyKey          String?
  resolvedAt              DateTime?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@unique([orderId, idempotencyKey])
  @@index([orderId, status])
  @@index([status, responseDeadlineAt])
  @@index([createdAt])
}

model Settlement {
  id                 String                  @id @default(cuid())
  orderId            String
  publisherId        String
  grossAmount        Decimal
  platformFee        Decimal                 @default(0)
  publisherAmount    Decimal
  status             SettlementStatus        @default(PENDING)
  reviewEndsAt       DateTime?
  releasePolicy      SettlementReleasePolicy @default(AUTO)
  settledAt          DateTime?
  version            Int                     @default(0)
  // ── Phase 6 reporting snapshots (additive; NULL on legacy rows) ──
  // Captured at settlement creation by joining the order's snapshot. Frozen
  // forever so refunds, audits, and reports can re-derive the contract
  // even after the publisher edits the listing.
  listingServiceId   String?
  serviceType        ServiceType?
  ownerType          WebsiteOwnershipType?
  fulfillmentChannel FulfillmentChannel?
  unitPrice          Decimal?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  order                 Order                  @relation(fields: [orderId], references: [id])
  publisher             Publisher              @relation(fields: [publisherId], references: [id])
  approvals             SettlementApproval[]
  transactions          Transaction[]
  listingService        ListingService?        @relation(fields: [listingServiceId], references: [id])
  withdrawalAllocations WithdrawalAllocation[]

  // NOTE: two indexes live in raw SQL migrations because Prisma can't
  // express them in @@index:
  //   - Settlement_orderId_active_key — partial UNIQUE on (orderId)
  //     WHERE status != 'CANCELLED' (Phase 6.x)
  //   - Settlement_status_reviewEndsAt_idx — composite on
  //     (status, reviewEndsAt) via CREATE INDEX CONCURRENTLY (Phase 7.13.1)
  // Do not remove either when regenerating migrations.
  //
  // Phase 7.13.1.1 dropped the redundant single-column @@index([status]) —
  // the composite Settlement_status_reviewEndsAt_idx covers WHERE status = X
  // via its leading column, so a separate single-column status index was dead
  // weight. publisherId+status filters still use Settlement_publisherId_status_idx;
  // orderId+status filters still use the partial unique above.
  @@index([orderId])
  @@index([publisherId, status])
  @@index([serviceType])
  @@index([fulfillmentChannel])
  @@index([listingServiceId])
}

enum SettlementApprovalType {
  CUSTOMER
  ADMIN
}

model SettlementApproval {
  id           String                 @id @default(cuid())
  settlementId String
  settlement   Settlement             @relation(fields: [settlementId], references: [id])
  type         SettlementApprovalType
  approvedBy   String
  roleAtTime   String
  approvedAt   DateTime               @default(now())

  @@unique([settlementId, type])
  @@index([settlementId])
}

// ── Order delivery: verification, evidence, fulfillment assignment ──────────
// A delivery is not a human "done" claim. It is an immutable versioned record
// (OrderDeliveryVersion) plus platform-captured evidence + snapshot. Settlement
// gates on independent verification, never on the claim alone.

enum FulfillmentAssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  DELIVERED
  CANCELLED
}

enum DeliveryVerificationStatus {
  PENDING
  VERIFIED
  FAILED
  MANUAL_REVIEW
  RETRYING
}

enum DeliveryInterventionStatus {
  NONE
  APPROVED
  REJECTED
  OVERRIDDEN
}

// Platform-owned orders enter the Operations queue. Operations claims/assigns
// and fulfills; identical downstream verification + settlement path as
// publisher inventory (no bypass for platform inventory).
model FulfillmentAssignment {
  id               String                      @id @default(cuid())
  orderId          String
  assignedToUserId String
  assignedByUserId String
  assignedAt       DateTime                    @default(now())
  completedAt      DateTime?
  status           FulfillmentAssignmentStatus @default(ASSIGNED)
  version          Int                         @default(0)
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  // NOTE: Phase 7.14 adds a partial unique index
  // `FulfillmentAssignment_orderId_active_unique` over (orderId) WHERE status IN
  // ('ASSIGNED', 'IN_PROGRESS') via raw SQL — Prisma's @@unique syntax doesn't
  // express partial predicates. Closes #23 (audit 2026-06-15): the prior
  // findFirst-pre-check-then-upsert pattern in claim() let two concurrent Ops
  // both succeed; the partial unique makes the race structurally impossible
  // (the second-to-commit hits P2002, mapped to ConflictException). Prisma's
  // drift detection ignores raw-SQL indexes, so the @@index declarations
  // below stay accurate.
  @@index([orderId])
  @@index([assignedToUserId, status])
  @@index([status])
}

// Immutable delivery version. Revisions create NEW versions; nothing is ever
// overwritten or deleted. Order.activeDeliveryVersionId points at the current.
model OrderDeliveryVersion {
  id                        String                      @id @default(cuid())
  orderId                   String
  version                   Int
  publishedUrl              String
  normalizedUrl             String
  articleTitle              String?
  notes                     String?
  screenshotUrl             String?
  submittedByUserId         String
  submittedAt               DateTime                    @default(now())
  verificationStatus        DeliveryVerificationStatus  @default(PENDING)
  verificationFailureReason String?
  interventionStatus        DeliveryInterventionStatus  @default(NONE)
  supersededByVersion       Int?
  // Optimistic-lock guard for worker/intervention transitions
  verificationVersion       Int                         @default(0)
  adminVerifiedById         String?
  adminOverrideReason       VerificationOverrideReason?
  adminVerifiedNotes        String?
  createdAt                 DateTime                    @default(now())

  order           Order                          @relation("OrderDeliveryVersions", fields: [orderId], references: [id])
  activeOrder     Order?                         @relation("ActiveOrderDeliveryVersion")
  evidence        DeliveryVerificationEvidence[]
  snapshots       DeliverySnapshot[]
  fraudFlags      DeliveryFraudFlag[]
  adminVerifiedBy User?                          @relation("AdminVerifiedVersion", fields: [adminVerifiedById], references: [id])

  @@unique([orderId, version])
  @@index([orderId])
  @@index([verificationStatus])
  @@index([normalizedUrl])
}

// Immutable verification evidence — survives disputes + revisions forever.
model DeliveryVerificationEvidence {
  id                 String   @id @default(cuid())
  deliveryVersionId  String
  pageTitle          String?
  metaTitle          String?
  canonicalUrl       String?
  resolvedUrl        String
  httpStatus         Int
  anchorFound        Boolean  @default(false)
  linkFound          Boolean  @default(false)
  targetUrlMatched   Boolean  @default(false)
  verifiedAnchorText String?
  verifiedTargetUrl  String?
  htmlHash           String?
  redirectChain      Json?
  checkedAt          DateTime @default(now())
  createdAt          DateTime @default(now())

  deliveryVersion OrderDeliveryVersion @relation(fields: [deliveryVersionId], references: [id])

  @@index([deliveryVersionId])
}

// Raw HTML + headers stored permanently in object storage (MinIO dev / R2 prod).
model DeliverySnapshot {
  id                  String   @id @default(cuid())
  deliveryVersionId   String
  htmlObjectKey       String
  screenshotObjectKey String?
  responseHeaders     Json?
  createdAt           DateTime @default(now())

  deliveryVersion OrderDeliveryVersion @relation(fields: [deliveryVersionId], references: [id])

  @@index([deliveryVersionId])
}

model DeliveryFraudFlag {
  id                String   @id @default(cuid())
  orderId           String
  deliveryVersionId String
  type              String
  details           Json?
  createdAt         DateTime @default(now())

  order           Order                @relation(fields: [orderId], references: [id])
  deliveryVersion OrderDeliveryVersion @relation(fields: [deliveryVersionId], references: [id])

  @@index([orderId])
  @@index([deliveryVersionId])
  @@index([type])
}

// Per-order review left by the customer after completion. One per order; feeds
// the publisher trust rating (separate from listing-level MarketplaceReview).
model OrderReview {
  id          String   @id @default(cuid())
  orderId     String   @unique
  publisherId String?
  customerId  String
  rating      Int // 1..5
  comment     String?
  createdAt   DateTime @default(now())

  order     Order      @relation(fields: [orderId], references: [id])
  publisher Publisher? @relation(fields: [publisherId], references: [id])

  @@index([publisherId])
  @@index([customerId])
}

model PublisherBalance {
  id                         String    @id @default(cuid())
  publisherId                String    @unique
  pendingBalance             Decimal   @default(0)
  approvedBalance            Decimal   @default(0)
  withdrawableBalance        Decimal   @default(0)
  // Owed back to the platform (refund clawback exceeded withdrawable).
  // Netted against future settlement releases before crediting withdrawable.
  debtBalance                Decimal   @default(0)
  lifetimeEarnings           Decimal   @default(0)
  lifetimePaid               Decimal   @default(0)
  // Allocation cutover captures the pre-provider-neutral withdrawable balance
  // as one honest carry-forward bucket. New releases after this timestamp are
  // allocated to their exact settlement transactions.
  allocationCutoverAt        DateTime?
  allocationCarryForward     Decimal   @default(0)
  allocationCarryForwardUsed Decimal   @default(0)
  version                    Int       @default(0)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  publisher Publisher @relation(fields: [publisherId], references: [id])
}

model Withdrawal {
  id               String           @id @default(cuid())
  publisherId      String
  amount           Decimal
  currency         String           @default("USD")
  publicReference  String?          @unique
  payoutFee        Decimal          @default(0)
  netAmount        Decimal?
  feePolicyVersion String?          @db.VarChar(64)
  method           String           @default("bank_transfer")
  status           WithdrawalStatus @default(PENDING)
  // Tier-based hold: approval is rejected before this timestamp.
  availableAt      DateTime?
  // Client-supplied dedup key — scoped per publisher, never used as PK.
  idempotencyKey   String?
  payoutMethodId   String?
  payoutBatchId    String?
  approvedBy       String?
  approvedAt       DateTime?
  version          Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  publisher      Publisher              @relation(fields: [publisherId], references: [id])
  approvedByUser User?                  @relation("WithdrawalApprover", fields: [approvedBy], references: [id])
  payoutMethod   PayoutMethod?          @relation(fields: [payoutMethodId], references: [id])
  payoutBatch    PayoutBatch?           @relation(fields: [payoutBatchId], references: [id])
  executions     PayoutExecution[]
  allocations    WithdrawalAllocation[]

  @@unique([publisherId, idempotencyKey])
  @@index([publisherId, status])
  @@index([approvedBy])
  @@index([status])
  @@index([payoutMethodId])
  @@index([payoutBatchId])
}

model PayoutMethod {
  id                   String   @id @default(cuid())
  publisherId          String
  type                 String // bank_transfer, paypal, wise
  label                String
  details              Json // AES-256-GCM encrypted via PayoutEncryptionService
  displayDetails       Json? // Non-sensitive display fields (bank name, last4) — unencrypted, safe for list endpoints
  encryptionKeyVersion Int      @default(0)
  isDefault            Boolean  @default(false)
  isActive             Boolean  @default(true)
  version              Int      @default(0)
  providerAccountId    String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  publisher       Publisher                 @relation(fields: [publisherId], references: [id])
  withdrawals     Withdrawal[]
  providerAccount PublisherProviderAccount? @relation(fields: [providerAccountId], references: [id])

  @@index([publisherId])
  @@index([providerAccountId])
}

// A provider recipient/account is separate from a payout method. This lets a
// BANK_ACCOUNT method route through Stripe now and Wise/local-bank adapters in
// the future without asking the publisher to re-enter destination details.
model PublisherProviderAccount {
  id                       String                         @id @default(cuid())
  publisherId              String
  provider                 String                         @db.VarChar(32)
  providerAccountId        String                         @db.VarChar(191)
  status                   PublisherProviderAccountStatus @default(PENDING_ONBOARDING)
  country                  String?                        @db.VarChar(2)
  defaultCurrency          String?                        @db.VarChar(3)
  transfersEnabled         Boolean                        @default(false)
  payoutsEnabled           Boolean                        @default(false)
  detailsSubmitted         Boolean                        @default(false)
  payoutScheduleConfigured Boolean                        @default(false)
  requirementsDue          Json?
  lastSyncedAt             DateTime?
  isActive                 Boolean                        @default(true)
  createdAt                DateTime                       @default(now())
  updatedAt                DateTime                       @updatedAt

  publisher     Publisher      @relation(fields: [publisherId], references: [id])
  payoutMethods PayoutMethod[]

  @@unique([publisherId, provider])
  @@unique([provider, providerAccountId])
  @@index([provider, status])
}

model PayoutProvider {
  id                         String   @id @default(cuid())
  name                       String   @unique // "manual", "wise", "stripe_connect"
  displayName                String
  config                     Json // Provider-specific config (API keys, webhook secrets) — AES-256-GCM encrypted
  configEncryptionKeyVersion Int      @default(0)
  isActive                   Boolean  @default(true)
  version                    Int      @default(0)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  executions PayoutExecution[]

  @@index([isActive])
}

model PayoutExecution {
  id                  String                @id @default(cuid())
  withdrawalId        String
  providerId          String
  status              PayoutExecutionStatus @default(PENDING)
  providerExecutionId String? // Provider's reference ID (transfer ID, payment ID)
  providerTransferId  String?               @db.VarChar(191)
  providerPayoutId    String?               @db.VarChar(191)
  amount              Decimal
  fee                 Decimal               @default(0)
  sourceCurrency      String                @default("USD") @db.VarChar(3)
  destinationCurrency String                @default("USD") @db.VarChar(3)
  destinationAmount   Decimal?
  providerFee         Decimal               @default(0)
  requestedReference  String?               @db.VarChar(64)
  acceptedReference   String?               @db.VarChar(64)
  bankTraceReference  String?               @db.VarChar(191)
  stage               String                @default("CREATED") @db.VarChar(64)
  errorMessage        String?
  providerMetadata    Json?
  idempotencyKey      String?
  version             Int                   @default(0)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  withdrawal Withdrawal     @relation(fields: [withdrawalId], references: [id])
  provider   PayoutProvider @relation(fields: [providerId], references: [id])

  @@unique([withdrawalId, idempotencyKey])
  @@unique([providerId, providerExecutionId])
  @@unique([providerId, providerTransferId])
  @@unique([providerId, providerPayoutId])
  @@index([withdrawalId, status])
  @@index([providerId, status])
  @@index([status, createdAt])
  @@index([providerExecutionId])
  @@index([providerPayoutId])
}

// Immutable source breakdown for a withdrawal. releasedAt marks an allocation
// returned to the publisher after a rejected/reversed withdrawal without
// deleting financial history.
model WithdrawalAllocation {
  id                  String       @id @default(cuid())
  withdrawalId        String
  sourceType          String       @db.VarChar(32)
  sourceTransactionId String?
  settlementId        String?
  orderId             String?
  amount              Decimal
  currency            String       @default("USD") @db.VarChar(3)
  sequence            Int
  serviceType         ServiceType?
  releasedAt          DateTime?
  createdAt           DateTime     @default(now())

  withdrawal        Withdrawal   @relation(fields: [withdrawalId], references: [id])
  sourceTransaction Transaction? @relation(fields: [sourceTransactionId], references: [id])
  settlement        Settlement?  @relation(fields: [settlementId], references: [id])
  order             Order?       @relation(fields: [orderId], references: [id])

  @@unique([withdrawalId, sequence])
  @@unique([withdrawalId, sourceTransactionId])
  @@index([sourceTransactionId, releasedAt])
  @@index([settlementId])
  @@index([orderId])
}

model PayoutWebhookEvent {
  id                  String                   @id @default(cuid())
  provider            String                   @db.VarChar(32)
  // SHA-256 of the provider event id, or of the verified raw payload when the
  // provider supplies no event id. Never use only the transfer id here: one
  // transfer legitimately emits several distinct state-change events.
  dedupKey            String                   @db.VarChar(64)
  eventType           String                   @db.VarChar(191)
  providerExecutionId String?                  @db.VarChar(191)
  providerStatus      String?                  @db.VarChar(32)
  rawStatus           String?                  @db.VarChar(100)
  status              PayoutWebhookEventStatus @default(PENDING)
  attempts            Int                      @default(0)
  availableAt         DateTime                 @default(now())
  lockedAt            DateTime?
  processedAt         DateTime?
  lastError           String?                  @db.VarChar(100)
  receivedAt          DateTime                 @default(now())
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@unique([provider, dedupKey])
  @@index([status, availableAt, receivedAt])
  @@index([providerExecutionId])
}

model PayoutBatch {
  id              String            @id @default(cuid())
  name            String
  status          PayoutBatchStatus @default(PENDING)
  totalAmount     Decimal           @default(0)
  totalCount      Int               @default(0)
  completedAmount Decimal           @default(0)
  completedCount  Int               @default(0)
  failedCount     Int               @default(0)
  notes           String?
  metadata        Json?
  createdBy       String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  withdrawals Withdrawal[]

  @@index([status, createdAt])
  @@index([createdBy])
}

model ApiKey {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  keyHash        String    @unique
  permissions    Json      @default("[]")
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model ContentOrder {
  id          String             @id @default(cuid())
  title       String
  brief       String?
  status      ContentOrderStatus @default(PENDING)
  deliverable String?
  orderId     String             @unique
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  order Order @relation(fields: [orderId], references: [id])
}

enum OrderArticleSource {
  CUSTOMER
  PUBLISHER
  OPERATIONS
}

enum OrderArticlePurpose {
  SOURCE_ARTICLE
  FINAL_SUBMISSION
}

enum OrderArticleFormat {
  PLAIN_TEXT
  MARKDOWN
}

model OrderArticleVersion {
  id              String              @id @default(cuid())
  orderId         String
  version         Int
  source          OrderArticleSource
  purpose         OrderArticlePurpose
  title           String?             @db.VarChar(200)
  body            String              @db.Text
  format          OrderArticleFormat  @default(MARKDOWN)
  checksum        String              @db.VarChar(64)
  wordCount       Int
  createdByUserId String
  supersedesId    String?
  createdAt       DateTime            @default(now())

  order        Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  supersedes   OrderArticleVersion?  @relation("ArticleVersionHistory", fields: [supersedesId], references: [id], onDelete: SetNull)
  supersededBy OrderArticleVersion[] @relation("ArticleVersionHistory")

  @@unique([orderId, source, purpose, version])
  @@index([orderId, purpose, createdAt])
  @@index([createdByUserId])
  @@index([supersedesId])
}

model Revision {
  id        String         @id @default(cuid())
  notes     String?
  files     Json?
  status    RevisionStatus @default(REQUESTED)
  orderId   String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model Report {
  id         String    @id @default(cuid())
  type       String
  data       Json?
  format     String    @default("pdf")
  exportedAt DateTime?
  orderId    String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model PlatformRevenue {
  id                 String                @id @default(cuid())
  orderId            String                @unique
  amount             Decimal
  platformFee        Decimal               @default(0)
  netRevenue         Decimal
  recordedAt         DateTime              @default(now())
  // Set on refund instead of deleting the row — financial records are
  // never destroyed. Revenue queries must filter reversedAt: null.
  reversedAt         DateTime?
  // Phase 6 reporting snapshots — same shape as Settlement.
  listingServiceId   String?
  serviceType        ServiceType?
  ownerType          WebsiteOwnershipType?
  fulfillmentChannel FulfillmentChannel?
  unitPrice          Decimal?
  createdAt          DateTime              @default(now())

  order          Order           @relation(fields: [orderId], references: [id])
  listingService ListingService? @relation(fields: [listingServiceId], references: [id])

  @@index([recordedAt])
  @@index([serviceType])
  @@index([fulfillmentChannel])
  @@index([listingServiceId])
}

model Wallet {
  id               String   @id @default(cuid())
  availableBalance Decimal  @default(0)
  reservedBalance  Decimal  @default(0)
  currency         String   @default("USD")
  organizationId   String?
  userId           String?
  version          Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization    Organization?    @relation(fields: [organizationId], references: [id])
  transactions    Transaction[]
  depositAttempts DepositAttempt[]
  // Partial unique index for legacy personal wallets only. A global userId
  // unique would break users who create wallets for multiple organizations.
  // See migration 20260719120000_wallet_personal_user_unique.

  @@unique([organizationId])
  @@index([userId])
}

enum TransactionType {
  DEPOSIT
  PURCHASE
  REFUND
  WITHDRAWAL
  WITHDRAWAL_REVERSAL
  SETTLEMENT_RELEASE
  SETTLEMENT_CLAWBACK
  DEBT_REPAYMENT
  RESERVATION
  // Chargeback lost at the bank — money left the platform permanently.
  // Included in wallet reconciliation sums (unlike RESERVATION).
  CHARGEBACK
}

model Transaction {
  id           String          @id @default(cuid())
  amount       Decimal
  currency     String          @default("USD")
  type         TransactionType
  reference    String?
  // External provider linkage (e.g. Stripe payment_intent for deposits) —
  // lets chargeback webhooks find the originating deposit + wallet.
  providerRef  String?
  // FIN-02: paired with `providerRef` to form a provider-aware uniqueness
  // key for external deposits (Stripe, Wise, manual, etc.). Composite key
  // `[provider, providerRef]` is realised at the DB level via a partial
  // unique index (migration `20260716030403_fin02_transaction_provider_unique`)
  // scoped to `WHERE "providerRef" IS NOT NULL`. Internal ledger rows
  // (PURCHASE / REFUND / WITHDRAWAL / SETTLEMENT_CLAWBACK / etc.) carry
  // `providerRef = null` and stay exempt — same partial-unique pattern
  // used by `MarketplaceFavorite_userId_listingId_serviceType_key` and
  // `MarketplaceListing_websiteId_active_key`. Prisma's `@@unique` syntax
  // doesn't express partial predicates, so the constraint lives in raw SQL.
  provider     String?
  description  String?
  walletId     String?
  orderId      String?
  publisherId  String?
  settlementId String?
  createdAt    DateTime        @default(now())

  wallet                Wallet?                @relation(fields: [walletId], references: [id])
  order                 Order?                 @relation(fields: [orderId], references: [id])
  publisher             Publisher?             @relation(fields: [publisherId], references: [id])
  settlement            Settlement?            @relation(fields: [settlementId], references: [id])
  depositAttempt        DepositAttempt?
  withdrawalAllocations WithdrawalAllocation[]

  @@unique([reference])
  @@index([walletId])
  @@index([walletId, type])
  @@index([orderId])
  @@index([createdAt])
  @@index([publisherId])
  @@index([settlementId])
  @@index([providerRef])
  @@index([provider, providerRef])
}

// Provider-neutral customer funding record. The provider adapter may create or
// inspect external objects, but only the billing domain can attach a ledger
// transaction and move wallet balances.
model DepositAttempt {
  id                  String               @id @default(cuid())
  publicReference     String               @unique @db.VarChar(32)
  walletId            String
  organizationId      String?
  createdByUserId     String
  method              String               @db.VarChar(32)
  provider            String               @db.VarChar(32)
  amount              Decimal
  walletCredit        Decimal
  customerFee         Decimal              @default(0)
  providerFee         Decimal?
  currency            String               @default("USD") @db.VarChar(3)
  status              DepositAttemptStatus @default(CREATED)
  idempotencyKey      String               @db.VarChar(191)
  providerSessionId   String?              @unique @db.VarChar(191)
  providerPaymentId   String?              @db.VarChar(191)
  providerChargeId    String?              @db.VarChar(191)
  intendedOrderId     String?
  ledgerTransactionId String?              @unique
  expiresAt           DateTime?
  completedAt         DateTime?
  failedAt            DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  wallet            Wallet                 @relation(fields: [walletId], references: [id])
  organization      Organization?          @relation(fields: [organizationId], references: [id])
  ledgerTransaction Transaction?           @relation(fields: [ledgerTransactionId], references: [id])
  providerEvents    PaymentProviderEvent[]

  @@unique([walletId, idempotencyKey])
  @@index([organizationId, status])
  @@index([provider, providerPaymentId])
  @@index([createdAt])
}

model PaymentProviderEvent {
  id               String                     @id @default(cuid())
  provider         String                     @db.VarChar(32)
  providerEventId  String                     @db.VarChar(191)
  eventType        String                     @db.VarChar(191)
  objectId         String?                    @db.VarChar(191)
  depositAttemptId String?
  status           PaymentProviderEventStatus @default(PENDING)
  attempts         Int                        @default(0)
  availableAt      DateTime                   @default(now())
  lockedAt         DateTime?
  processedAt      DateTime?
  lastError        String?                    @db.VarChar(100)
  receivedAt       DateTime                   @default(now())
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  depositAttempt DepositAttempt? @relation(fields: [depositAttemptId], references: [id])

  @@unique([provider, providerEventId])
  @@index([status, availableAt, receivedAt])
  @@index([depositAttemptId])
  @@index([objectId])
}

model Ticket {
  id                  String              @id @default(cuid())
  subject             String
  description         String?
  status              TicketStatus        @default(OPEN)
  organizationId      String
  userId              String
  // Optional link to the order the ticket is about — lets customers get help
  // straight from an order and gives staff full context.
  orderId             String?
  // Phase 6.5 channel-aware routing. Snapshotted from the linked order at
  // ticket creation; subsequent website/listing edits never re-route an
  // existing ticket (prevents accidental exposure to a new owner).
  //   - PLATFORM channel: assignedToUserId = Website.managedByUserId at the
  //     moment the ticket was opened. NULL falls back to the unassigned-Ops
  //     queue surfaced to every OPERATIONS staffer.
  //   - PUBLISHER channel: assignedPublisherId = Website.publisherId. Reply
  //     access then keys off PublisherMembership rather than a single user.
  fulfillmentChannel  FulfillmentChannel?
  assignedToUserId    String?
  assignedPublisherId String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  organization      Organization    @relation(fields: [organizationId], references: [id])
  user              User            @relation(fields: [userId], references: [id])
  order             Order?          @relation(fields: [orderId], references: [id])
  assignedTo        User?           @relation("TicketAssignee", fields: [assignedToUserId], references: [id])
  assignedPublisher Publisher?      @relation("TicketPublisher", fields: [assignedPublisherId], references: [id])
  messages          TicketMessage[]

  @@index([organizationId, status])
  @@index([userId])
  @@index([status])
  @@index([orderId])
  @@index([assignedToUserId, status])
  @@index([assignedPublisherId, status])
  @@index([fulfillmentChannel, status])
}

// Phase 6.6: every ticket message carries a visibility scope. PUBLIC is the
// historical default and what every existing row gets at migration time;
// INTERNAL is staff-only — invisible to the ticket's customer and to any
// publisher member, and used by Finance (who is read-only on PLATFORM tickets)
// + Admin + Ops as an escape valve to coordinate without writing to the
// customer-facing thread.
enum TicketMessageVisibility {
  PUBLIC
  INTERNAL
}

// Phase 6.6.1: which "hat" the author was wearing at write time. Snapshotted
// onto every TicketMessage row — never derived dynamically from current
// memberships, so historical audit trails remain accurate even after a
// staffer's role changes. This is the same forensic discipline as
// SettlementApproval.roleAtTime.
//
// Used for:
//   - Dispute / refund / settlement investigations ("who said what in what
//     capacity?")
//   - Staff QA reviews ("Finance posted on a Platform ticket — that's the
//     internal-note escape valve in action")
//   - Audit log enrichment (TICKET_MESSAGE_ADDED metadata carries this so
//     reports can group by role without a join through StaffMembership)
enum TicketParticipantRole {
  CUSTOMER
  PUBLISHER
  OPS
  ADMIN
  FINANCE
}

// Phase 6.6.1: orthogonal to visibility. MESSAGE = human reply (default);
// INTERNAL_NOTE = staff-only note (visibility is always INTERNAL); SYSTEM_EVENT
// = machine-emitted thread entry (reassigned, status changed, auto-resolved).
// SYSTEM_EVENT is schema-ready but not yet emitted by any service path; it
// lets the UI render system entries distinctly from human messages without
// requiring a parallel "events" table.
enum TicketMessageType {
  MESSAGE
  INTERNAL_NOTE
  SYSTEM_EVENT
}

model TicketMessage {
  id              String                  @id @default(cuid())
  content         String
  files           Json?
  visibility      TicketMessageVisibility @default(PUBLIC)
  // Phase 6.6.1: role-at-write-time + message classification snapshot.
  participantRole TicketParticipantRole
  messageType     TicketMessageType       @default(MESSAGE)
  // Phase 6.6.2: full actor context snapshot — uncollapsed companion to
  // participantRole. Captures the raw schema-level roles the actor held at
  // write time so investigations can answer "was this CUSTOMER an OWNER or
  // MEMBER?" / "was this STAFF SUPER_ADMIN or FINANCE?" without joining
  // through StaffMembership/Membership (which mutate over time and would
  // lie about historical authority).
  //
  // Shape (open — future fields like permissions[] can be added without a
  // migration):
  //   { kind: "CUSTOMER" | "PUBLISHER" | "STAFF",
  //     staffRole: "SUPER_ADMIN" | "OPERATIONS" | "FINANCE" | null,
  //     organizationRole: "OWNER" | "MEMBER" | null,
  //     publisherRole: "PUBLISHER_OWNER" | "PUBLISHER_MEMBER" | null }
  //
  // Nullable for backward compat — pre-migration rows have NULL.
  actorSnapshot   Json?
  // Phase 8.12 — made nullable with onDelete: SetNull so user deletion
  // (when built) nullifies the actor reference without losing message history.
  userId          String?
  ticketId        String
  createdAt       DateTime                @default(now())

  // Phase 6.5 FK; Phase 8.12 added onDelete: SetNull.
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
  // Composite covers the "show me the customer-visible thread" read path
  // (ticketId + visibility=PUBLIC) without a separate scan.
  @@index([ticketId, visibility])
  // Audit / investigation filter: "all FINANCE messages on this ticket",
  // "all OPS replies in this window".
  @@index([ticketId, participantRole])
}

model Notification {
  id             String   @id @default(cuid())
  type           String
  message        String
  read           Boolean  @default(false)
  // Phase 8.12 — made nullable with onDelete: SetNull so user deletion
  // nullifies the reference without losing notification history.
  userId         String?
  // Nullable: staff/system notifications (e.g. chargeback alerts) have no org.
  organizationId String?
  // Phase 7.4 (audit #12) — when writers supply a deterministic key (e.g.
  // `recon:walletDrift:wallet-abc:user-xyz:2026-06-16`), the unique constraint
  // below catches BullMQ-retry duplicates. NULL = no dedup applies (legacy
  // path; the partial unique index below excludes NULL rows, so multiple
  // NULLs coexist freely). Builders live in packages/shared/src/notification-dedup-keys.ts.
  dedupKey       String?  @db.VarChar(256)
  createdAt      DateTime @default(now())

  // Phase 7.4 FK; Phase 8.12 added onDelete: SetNull.
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id])

  // Partial unique — see migration 20260616100000_phase74_notification_dedup.
  // Prisma doesn't model partial uniques directly; this @@unique mirrors the
  // SQL constraint name. NULL dedupKey rows are exempt.
  @@unique([userId, dedupKey], map: "Notification_userId_dedupKey_key")
  @@index([userId, read, createdAt])
  @@index([organizationId, createdAt])
  @@index([read])
}

model AuditLog {
  id             String   @id @default(cuid())
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  // Phase 7.7 A1 — requestId promoted to indexed top-level column for
  // forensic SQL queries (WHERE requestId = '<id>'). Continues to be
  // mirrored into metadata.requestId for downstream consumers; both
  // writes happen in AuditService.log(). VARCHAR(128) matches the
  // isValidRequestId allowlist regex in shared/observability/request-context.
  requestId      String?  @db.VarChar(128)
  // Nullable: system/webhook actions and platform-scope actions have no
  // real user/org. Sentinel strings ("SYSTEM") violated the FK and were
  // silently dropped by the audit service — never reintroduce them.
  userId         String?
  organizationId String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  user         User?         @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId, action, createdAt])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([action])
  // Partial unique index (WHERE requestId IS NOT NULL) — see migration
  // 20260616130000_phase77_audit_request_id_column. Prisma doesn't model
  // partial predicates; this @@index mirrors the SQL constraint name.
  @@index([requestId], map: "AuditLog_requestId_idx")
}

// =============================================================================
// MARKETPLACE MODELS
// =============================================================================

// Phase 7: enum ListingType removed. The deprecated MarketplaceListing.type
// column it backed is gone; service offerings are now expressed as
// ServiceType values on ListingService rows.

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  PAUSED
  ARCHIVED
}

enum ListingFulfillmentType {
  INTERNAL
  PUBLISHER
  HYBRID
}

enum ListingLinkType {
  DOFOLLOW
  NOFOLLOW
  SPONSORED
  UGC
}

enum ListingLinkValidity {
  PERMANENT
  FIVE_YEARS
  ONE_YEAR
  SIX_MONTHS
  THREE_MONTHS
}

model MarketplaceCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  parentId    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   MarketplaceCategory?         @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children MarketplaceCategory[]        @relation("CategoryHierarchy")
  listings MarketplaceListingCategory[]

  @@index([slug])
  @@index([parentId])
}

model MarketplaceTag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  listings MarketplaceListingTag[]
}

model MarketplaceListing {
  id               String                 @id @default(cuid())
  title            String
  slug             String                 @unique
  description      String
  shortDescription String?
  // Phase 7 cleanup: `type` / `price` / `turnaroundDays` / `revisionRounds`
  // / `warrantyDays` were dropped — per-service data lives on the
  // ListingService child table. See migration 20260615130000_phase7_listing_columns.
  status           ListingStatus          @default(DRAFT)
  fulfillmentType  ListingFulfillmentType @default(PUBLISHER)
  // Authoritative ownership at the listing layer. Backfilled in Phase 1 from
  // (publisherId IS NOT NULL ? PUBLISHER : PLATFORM). Routing, attribution
  // ("Listed by GuestPost.cc"), and approval-queue gating read this column.
  ownerType        WebsiteOwnershipType   @default(PUBLISHER)

  // Pricing — listing-level columns dropped in Phase 7. Reads use priceFrom
  // (computed from AVAILABLE ListingService rows).
  currency  String   @default("USD")
  priceType String   @default("fixed") // fixed, starting_at, range, negotiable
  minPrice  Decimal?
  maxPrice  Decimal?

  // Metrics
  domainRating     Int?
  domainAuthority  Int?
  traffic          Int?
  referringDomains Int?
  spamScore        Int?

  // Location & Language
  country   String?
  language  String?
  countries String[] @default([])
  languages String[] @default([])

  // Features
  featured     Boolean @default(false)
  verified     Boolean @default(false)
  // allowGuestPost / allowNicheEdit removed in Phase 5 cleanup — multi-service
  // listings encode service availability via the ListingService child table.
  doFollowOnly Boolean @default(false)

  // Placement-policy attributes are site/listing-level facts. Each listing
  // stores exactly one value for every policy; NULL is retained only for
  // pre-migration inventory until it is reviewed and resubmitted.
  sportsGamingAllowed    Boolean?
  pharmacyAllowed        Boolean?
  cryptoAllowed          Boolean?
  backlinkCount          Int?
  linkType               ListingLinkType?
  linkValidity           ListingLinkValidity?
  googleNews             Boolean?
  markedSponsored        Boolean?
  foreignLanguageAllowed Boolean?

  // URLs
  websiteUrl String?
  sampleUrl  String?
  signupUrl  String?

  // Metrics data (JSON for flexibility)
  metricsData Json?
  trafficData Json?
  semrushData Json?

  // Publisher reference (for PUBLISHER type)
  publisherId String?
  // Phase X: DB-level partial unique index `MarketplaceListing_websiteId_active_key`
  // on (websiteId) WHERE websiteId IS NOT NULL AND status != 'ARCHIVED' — at most
  // one active listing per website. Multiple services go on the same listing via
  // the ListingService child table. See migration 20260713120000_listing_per_website_unique.
  websiteId   String?

  // Organization reference (for INTERNAL and publisher listings)
  organizationId String?

  // Timestamps
  publishedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  publisher    Publisher?                   @relation(fields: [publisherId], references: [id])
  website      Website?                     @relation(fields: [websiteId], references: [id])
  organization Organization?                @relation(fields: [organizationId], references: [id])
  categories   MarketplaceListingCategory[]

  tags       MarketplaceListingTag[]
  images     MarketplaceListingImage[]
  // pricingTiers removed in Phase 5 — replaced by per-service prices on the
  // ListingService child table.
  reviews    MarketplaceReview[]
  favorites  MarketplaceFavorite[]
  savedLists MarketplaceSavedListItem[]
  views      MarketplaceListingView[]
  clicks     MarketplaceListingClick[]
  services   ListingService[]
  orders     Order[]

  // Phase X: Partial unique index `MarketplaceListing_websiteId_active_key`
  // exists at the DB level via custom migration 20260713120000. Not represented
  // in Prisma @@unique syntax because it is a partial index (WHERE clause).
  // See the migration SQL for the exact definition.

  @@index([slug])
  // Phase 7: @@index([type]) dropped alongside MarketplaceListing.type.
  @@index([status])
  @@index([publisherId])
  @@index([featured])
  @@index([createdAt])
  // Phase 7: @@index([price]) dropped alongside MarketplaceListing.price.
  // Sorting/filtering by price now hits the ListingService(availability,
  // serviceType, price) composite index.
  @@index([ownerType, status])
}

// A site can cover several niches, but marketplace quality controls cap the
// selection at seven in every API write path. The database join table keeps
// category filtering normalized and prevents duplicate selections.
model MarketplaceListingCategory {
  listingId  String
  categoryId String
  createdAt  DateTime @default(now())

  listing  MarketplaceListing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  category MarketplaceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@id([listingId, categoryId])
  @@index([categoryId, listingId])
}

// A purchasable service offering on a MarketplaceListing. One listing can
// expose N service rows — e.g. GUEST_POST at $150 / 7d AND NICHE_EDIT at $80
// / 3d on the same website — replacing the previous "one listing = one
// service" model. Order.create snapshots the chosen row's serviceType,
// price, currency, turnaroundDays onto the order, so later edits to this
// row never change the contract for in-flight orders.
model ListingService {
  id                  String              @id @default(cuid())
  listingId           String
  serviceType         ServiceType
  price               Decimal
  currency            String              @default("USD")
  turnaroundDays      Int
  revisionRounds      Int                 @default(2)
  warrantyDays        Int?
  // JSON, free-form publisher-defined requirements (anchorPolicy,
  // niches, min wordCount, do-follow only, content guidelines, ...).
  requirements        Json?
  // JSON, fulfillment configuration (autoAccept, internalSlaHours,
  // requiresBrief, ...). Read by routing services; never exposed publicly.
  fulfillmentSettings Json?
  availability        ServiceAvailability @default(AVAILABLE)
  // Optimistic-lock guard for concurrent edits + Order.create race.
  version             Int                 @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  listing          MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  orders           Order[]
  settlements      Settlement[]
  platformRevenues PlatformRevenue[]

  // A given service type can appear at most once per listing.
  @@unique([listingId, serviceType])
  @@index([listingId])
  @@index([serviceType, availability])
  @@index([availability])
  // Phase 6 search hot-path indexes for `services.some({…})` filters.
  @@index([availability, serviceType, price])
  @@index([availability, turnaroundDays])
}

model MarketplaceListingTag {
  listingId String
  tagId     String

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tag     MarketplaceTag     @relation(fields: [tagId], references: [id])

  @@id([listingId, tagId])
}

model MarketplaceListingImage {
  id        String   @id @default(cuid())
  listingId String
  url       String
  alt       String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

// MarketplacePricingTier removed in Phase 5 — fully replaced by per-service
// pricing on ListingService rows. See migration 20260614040000_phase5_cleanup.

model MarketplaceReview {
  id          String    @id @default(cuid())
  listingId   String
  userId      String
  rating      Int
  title       String?
  content     String
  response    String?
  respondedAt DateTime?
  status      String    @default("APPROVED") // APPROVED, PENDING, SPAM, FLAGGED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User               @relation(fields: [userId], references: [id])

  @@index([listingId])
  @@index([userId])
}

model MarketplaceFavorite {
  id          String       @id @default(cuid())
  userId      String
  listingId   String
  // NULL = "favorite the whole listing" (legacy semantics). Non-NULL = scoped
  // to a specific service on the listing — used by the WAITLIST notify-me
  // CTA. When a ListingService flips WAITLIST -> AVAILABLE, a worker fans out
  // to favorites where (listingId = X AND serviceType = Y OR serviceType IS NULL).
  serviceType ServiceType?
  createdAt   DateTime     @default(now())

  user    User               @relation(fields: [userId], references: [id])
  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  // NOTE: the @@unique below is realised as
  // `MarketplaceFavorite_userId_listingId_serviceType_key` with NULLS NOT
  // DISTINCT semantics (raw SQL — Prisma's @@unique syntax doesn't expose
  // NULL distinctness, but pg drift detection treats it as transparent).
  // The NULLS NOT DISTINCT modifier closes the Phase 7.12.1 TOCTOU race
  // on (userId, listingId, NULL) addFavorite calls — see Phase 7.13.2A/B
  // for the migration history (7.13.2A added the NULLS NOT DISTINCT index
  // alongside the original; 7.13.2B dropped the original + renamed the
  // new one to the canonical Prisma name).
  @@unique([userId, listingId, serviceType])
  @@index([userId])
  @@index([listingId])
  @@index([listingId, serviceType])
}

model MarketplaceSavedList {
  id        String   @id @default(cuid())
  userId    String
  name      String
  slug      String
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items MarketplaceSavedListItem[]

  @@unique([userId, slug])
  @@index([userId])
}

model MarketplaceSavedListItem {
  id        String   @id @default(cuid())
  listId    String
  listingId String
  note      String?
  addedAt   DateTime @default(now())

  list    MarketplaceSavedList @relation(fields: [listId], references: [id], onDelete: Cascade)
  listing MarketplaceListing   @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listId, listingId])
  @@index([listingId])
}

model MarketplaceListingView {
  id        String   @id @default(cuid())
  listingId String
  userId    String?
  sessionId String?
  ipAddress String?
  userAgent String?
  referrer  String?
  createdAt DateTime @default(now())

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([createdAt])
  @@index([userId])
}

model MarketplaceListingClick {
  id          String       @id @default(cuid())
  listingId   String
  userId      String?
  sessionId   String?
  ipAddress   String?
  action      String       @default("view") // view, click, cta_click, favorite, share
  // Phase 6: which service the user picked at click-time. NULL on listing-level
  // events (`view`, `favorite`, `share`) and on legacy rows.
  serviceType ServiceType?
  metadata    Json?
  createdAt   DateTime     @default(now())

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([createdAt])
  @@index([action])
  @@index([serviceType])
}

model MarketplaceSearchHistory {
  id          String       @id @default(cuid())
  userId      String?
  query       String
  filters     Json?
  resultCount Int?
  clickedId   String?
  // Phase 6: which service the user filtered for. Powers serviceType-aware
  // recommendation training. NULL on legacy rows or untyped searches.
  serviceType ServiceType?
  createdAt   DateTime     @default(now())

  @@index([userId])
  @@index([query])
  @@index([serviceType])
}

// AI Recommendations
model MarketplaceRecommendation {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  type      String // similar, recommended, frequently_bought, trending, because_you_viewed
  score     Float
  reason    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([listingId])
  @@index([type])
}

// Publisher Profiles for Marketplace
model PublisherProfile {
  id             String   @id @default(cuid())
  publisherId    String   @unique
  bio            String?
  stats          Json? // aggregated stats
  responseTime   Int? // avg response time in hours
  completionRate Float? // order completion rate
  rating         Float?
  // Internal publisher trust score 0-100 (folds in reviews, link uptime,
  // disputes, refunds, completion). Drives the publisher tier.
  trustScore     Int?
  totalReviews   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  publisher Publisher @relation(fields: [publisherId], references: [id])
}

// Fraud Detection
model MarketplaceFlag {
  id         String    @id @default(cuid())
  type       String // duplicate_domain, fake_traffic, spam_reviews, suspicious_pattern, mass_listing
  severity   String // low, medium, high, critical
  status     String    @default("OPEN") // OPEN, REVIEWING, RESOLVED, DISMISSED
  data       Json?
  resolvedBy String?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([type])
  @@index([status])
  @@index([severity])
}

// Fulfillment Rules
model ListingFulfillmentRule {
  id        String   @id @default(cuid())
  listingId String
  type      String // auto_assign, manual_review, price_threshold
  config    Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
}

// Singleton platform configuration (one row). Values resolved at runtime;
// historical settlements retain the rate captured at creation time.
model PlatformSettings {
  id             String   @id @default(cuid())
  platformFeePct Decimal  @default(20)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Integration Domain ─────────────────────────────────────────────────────

enum ExternalAccountStatus {
  ACTIVE
  EXPIRED
  REVOKED
  ERROR
}

enum IntegrationSyncJobType {
  SYNC
  BACKFILL
}

model ExternalAccount {
  id             String               @id @default(cuid())
  provider       String // GOOGLE, MICROSOFT
  externalUserId String
  // Credential ownership is explicit so the same Google identity can be
  // connected independently by a publisher and by the platform without
  // sharing or overwriting encrypted tokens across trust boundaries.
  ownerType      IntegrationOwnerType @default(PUBLISHER)
  ownerId        String
  email          String?
  displayName    String?

  encryptedAccessToken  String
  encryptedRefreshToken String
  tokenExpiresAt        DateTime
  grantedScopes         String[]

  status          ExternalAccountStatus @default(ACTIVE)
  lastDiscoveryAt DateTime?
  lastUsedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  integrations PublisherIntegration[]

  @@unique([provider, externalUserId, ownerType, ownerId])
  @@index([ownerType, ownerId])
  @@index([status])
}

model PublisherIntegration {
  id           String               @id @default(cuid())
  ownerType    IntegrationOwnerType @default(PUBLISHER)
  ownerId      String
  provider     IntegrationProvider
  connectionId String
  status       IntegrationStatus    @default(PENDING)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  connection          ExternalAccount        @relation(fields: [connectionId], references: [id])
  schedule            IntegrationSchedule?
  websiteIntegrations WebsiteIntegration[]
  syncs               IntegrationSync[]
  discoveries         IntegrationDiscovery[]

  @@unique([provider, connectionId])
  @@index([ownerType, ownerId])
  @@index([status])
}

model IntegrationSchedule {
  id                  String    @id @default(cuid())
  integrationId       String    @unique
  enabled             Boolean   @default(true)
  intervalMinutes     Int       @default(1440) // 24h; supports 15min–30d
  nextRunAt           DateTime
  lastRunAt           DateTime?
  lastSuccessAt       DateTime?
  lastFailureAt       DateTime?
  consecutiveFailures Int       @default(0)
  version             Int       @default(1) // optimistic lock
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  integration PublisherIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
}

model IntegrationDiscovery {
  id               String                @id @default(cuid())
  integrationId    String
  status           IntegrationSyncStatus @default(PENDING)
  resourcesFound   Int                   @default(0)
  resourcesCreated Int                   @default(0)
  errorMessage     String?
  startedAt        DateTime              @default(now())
  completedAt      DateTime?

  integration PublisherIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@index([status])
}

model WebsiteIntegration {
  id                   String                   @id @default(cuid())
  integrationId        String
  websiteId            String
  externalResourceId   String
  externalResourceName String?
  metadata             Json? // provider-owned
  status               WebsiteIntegrationStatus @default(CONNECTED)
  syncedAt             DateTime?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  integration PublisherIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  website     Website              @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@unique([integrationId, externalResourceId])
  // One property per provider integration per website. GSC and GA4 use
  // different integrationIds, so a website can (and should) link one of each.
  @@unique([integrationId, websiteId])
  @@index([websiteId])
  @@index([status])
}

model IntegrationSync {
  id                   String                 @id @default(cuid())
  integrationId        String
  websiteIntegrationId String?
  jobType              IntegrationSyncJobType @default(SYNC)
  status               IntegrationSyncStatus  @default(PENDING)
  trigger              IntegrationSyncTrigger @default(MANUAL)
  recordsProcessed     Int                    @default(0)
  recordsExpected      Int                    @default(0)
  itemsCompleted       Int                    @default(0)
  itemsTotal           Int                    @default(0)
  errorMessage         String?
  startedAt            DateTime               @default(now())
  completedAt          DateTime?

  integration PublisherIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@index([status])
  @@index([startedAt])
}

model WebsiteSearchDaily {
  id                  String   @id @default(cuid())
  websiteId           String
  sourceIntegrationId String
  date                DateTime @db.Date
  clicks              Int      @default(0)
  impressions         Int      @default(0)
  ctr                 Float    @default(0)
  position            Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([websiteId, sourceIntegrationId, date])
  @@index([websiteId, date])
  @@index([sourceIntegrationId, date])
  @@index([date])
}

model WebsiteAnalyticsDaily {
  id                  String   @id @default(cuid())
  websiteId           String
  sourceIntegrationId String
  date                DateTime @db.Date
  sessions            Int      @default(0)
  users               Int      @default(0)
  newUsers            Int      @default(0)
  pageviews           Int      @default(0)
  bounceRate          Float    @default(0)
  avgSessionDuration  Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([websiteId, sourceIntegrationId, date])
  @@index([websiteId, date])
  @@index([sourceIntegrationId, date])
  @@index([date])
}

model WebsitePageSearchDaily {
  id                  String   @id @default(cuid())
  websiteId           String
  sourceIntegrationId String
  pageUrl             String
  date                DateTime @db.Date
  clicks              Int      @default(0)
  impressions         Int      @default(0)
  ctr                 Float    @default(0)
  position            Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([websiteId, sourceIntegrationId, pageUrl, date])
  @@index([websiteId, date])
}
