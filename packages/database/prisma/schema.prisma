generator client {
  provider = "prisma-client"
  output   = "../src/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  CUSTOMER
  PUBLISHER
  STAFF
}

enum AccountSuspensionReason {
  SECURITY_RISK
  FRAUD_OR_ABUSE
  TERMS_VIOLATION
  PAYMENT_RISK
  COMPLIANCE
  STAFF_ACCESS_REMOVAL
  OTHER
  LEGACY
}

enum CustomerRole {
  OWNER
  MEMBER
}

enum PublisherRole {
  PUBLISHER_OWNER
  PUBLISHER_MEMBER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_REFUNDED
  RESOLVED_REJECTED
  RESOLVED_RESTORED
}

enum StaffRole {
  SUPER_ADMIN
  OPERATIONS
  FINANCE
}

// Deprecated: kept for migration compatibility, will be removed
enum UserRole {
  OWNER
  MANAGER
  SEO_SPECIALIST
  CLIENT_VIEWER
  PUBLISHER
  ADMIN
}

// Deprecated: kept for migration compatibility, will be removed
enum MemberRole {
  OWNER
  MANAGER
  SEO_SPECIALIST
  CLIENT_VIEWER
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ContentOrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum RevisionStatus {
  REQUESTED
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
  DRAFT
}

enum WebsiteOwnershipType {
  PUBLISHER
  PLATFORM
}

enum OrderStatus {
