{
  "name": "@guestpost/auth",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/client/index.js",
    "./react": "./dist/react/index.js",
    "./middleware": "./dist/middleware/index.js",
    "./server": "./dist/server/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest"
  },
  "dependencies": {
    "better-auth": "^1.6.23",
    "ioredis": "^5.4.1",
    "@guestpost/database": "workspace:*",
    "@guestpost/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^26.1.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/src/__tests__/**/*.spec.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js"
    ]
  }
}
