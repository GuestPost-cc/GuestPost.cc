node_modules/
.next/
dist/
.turbo/
.env
.env.local
.env.development
packages/database/.env
*.log
.DS_Store

# TypeScript incremental build cache
*.tsbuildinfo

# Stray compiled JS in TS source trees (build cruft from running tsc with
# wrong cwd / outDir). Real compiled output lives in dist/ per each
# tsconfig — these patterns catch files that accidentally land alongside
# their .ts source.
apps/*/src/**/*.js
apps/*/src/**/*.js.map
packages/*/src/**/*.js
packages/*/src/**/*.js.map

# IDE/editor local configs
.cursor/
.vscode/
.idea/

# Local project context & data
context.js
data/

# AI context and analysis (local only, not for CI)
.ai/
graphify-out/
.opencode

# bedrock: noisy auto-generated content excluded from git
# Curated knowledge (Memory/, Work/, History/, Evidence/imports/) IS tracked.
bedrock/Evidence/raw/
bedrock/Views/site/
bedrock/Views/graph/*.json
bedrock/Views/graph/*.md
bedrock/Views/graph/*.canvas
bedrock/Outputs/absorb-manifest.md
bedrock/.obsidian/workspace
bedrock/.obsidian/workspace.json
bedrock/.obsidian/workspaces.json
scripts/.wise-validation-key*
test-results/
