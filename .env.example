# Environment
NODE_ENV=development
PORT=4000

# Database
# DATABASE_URL must be a literal string — dotenv does NOT expand ${...}
# placeholders. Keep these three POSTGRES_* values aligned with the URL.
POSTGRES_USER=guestpost
POSTGRES_PASSWORD=guestpost
POSTGRES_DB=guestpost
DATABASE_URL=postgresql://guestpost:guestpost@localhost:5432/guestpost

# Redis
REDIS_URL=redis://localhost:6379

# MinIO
MINIO_ROOT_USER=guestpost
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=guestpost
MINIO_SECRET_KEY=change_me_in_production
MINIO_BUCKET=guestpost

# SMTP (Mailpit in dev, real SMTP in production)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@guestpost.local

# Stripe (test mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Auth
JWT_SECRET=generate_a_random_secret_with_openssl_rand_base64_32
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
BETTER_AUTH_URL=http://localhost:4000
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# Rate Limiting (override per-environment defaults; see main.ts for values)
# Auth endpoints
AUTH_RATE_LIMIT_LOGIN_MAX=
AUTH_RATE_LIMIT_REGISTER_MAX=
AUTH_RATE_LIMIT_MAGIC_LINK_MAX=
AUTH_RATE_LIMIT_RESET_MAX=

# Marketplace (applies to listings, categories, tags, stats, services)
MARKETPLACE_RATE_LIMIT_ANON_MAX=
MARKETPLACE_RATE_LIMIT_AUTH_MAX=

# General API fallback (all routes not matched above)
PUBLIC_RATE_LIMIT_MAX=
AUTHENTICATED_RATE_LIMIT_MAX=

# Admin API
ADMIN_RATE_LIMIT_MAX=

# Billing
BILLING_RATE_LIMIT_MAX=

# Apps
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=http://localhost:3001

# Worker — scheduled financial drift sweep interval (minutes, min 5)
RECONCILIATION_SWEEP_MINUTES=60

# Queue job HMAC signing (required in production, must differ from JWT_SECRET)
QUEUE_SIGNING_SECRET=
