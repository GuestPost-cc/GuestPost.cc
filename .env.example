# Environment
NODE_ENV=development
PORT=4000

# Database
# DATABASE_URL must be a literal string — dotenv does NOT expand ${...}
# placeholders. Keep these three POSTGRES_* values aligned with the URL.
POSTGRES_USER=guestpost
POSTGRES_PASSWORD=guestpost
POSTGRES_DB=guestpost
DATABASE_URL=postgresql://guestpost:guestpost@localhost:5432/guestpost    # REQUIRED

# Redis
REDIS_URL=redis://localhost:6379                                          # REQUIRED
# Optional dedicated BullMQ database. Falls back to REDIS_URL when empty.
# Separation prevents queue traffic/eviction policy from affecting auth,
# rate limits, cache, and pub/sub data.
QUEUE_REDIS_URL=

# MinIO
MINIO_ROOT_USER=guestpost
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=guestpost
MINIO_SECRET_KEY=change_me_in_production
MINIO_BUCKET=guestpost

# SMTP (Mailpit in dev, real SMTP in production)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@guestpost.local

# Stripe. Production/staging are fail-closed unless the direction-specific
# feature flag is explicitly true. Start with sk_test_ keys only.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PAYOUT_WEBHOOK_SECRET=
STRIPE_CONNECTED_PAYOUT_WEBHOOK_SECRET=
STRIPE_DEPOSITS_ENABLED=false
STRIPE_CONNECT_ENABLED=false
# Leave false for sandbox. Enabling live keys requires the documented release
# gates, legal eligibility, reconciliation, reserves, and controlled rollout.
STRIPE_LIVE_MODE_ENABLED=false
# Temporary escape hatch for encrypted legacy bank/PayPal/Wise methods. Keep
# false for the Stripe staging rollout; enabling requires provider certification.
PAYOUT_LEGACY_METHODS_ENABLED=false
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Auth
# Browser authentication uses Better Auth's opaque database sessions, not a
# JavaScript-readable JWT. JWT_SECRET is only a development fallback for old
# queue tooling; production requires a separate QUEUE_SIGNING_SECRET.
JWT_SECRET=development_queue_fallback_only
BETTER_AUTH_SECRET=generate_a_different_random_secret_with_openssl_rand_base64_32 # REQUIRED
BETTER_AUTH_URL=http://localhost:4000
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
# OAuth callback is a top-level navigation, so Lax keeps the state cookie
# available without granting third-party request access.
OAUTH_STATE_COOKIE_SAMESITE=lax
OAUTH_STATE_COOKIE_SECURE=false

# Google OAuth (Better Auth) — real values go in .env.development only (gitignored)
GOOGLE_CLIENT_ID=                                          # Google Cloud Console OAuth 2.0 Client ID (e.g. 123...apps.googleusercontent.com)
GOOGLE_CLIENT_SECRET=                                      # Google Cloud Console OAuth 2.0 Client Secret
# Add http://localhost:4000/api/v1/auth/callback/google as authorized redirect URI
# in Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# Rate Limiting (override per-environment defaults; see main.ts for values)
# Auth endpoints (per-IP, per-minute — first layer)
AUTH_RATE_LIMIT_LOGIN_MAX=
AUTH_RATE_LIMIT_REGISTER_MAX=
AUTH_RATE_LIMIT_MAGIC_LINK_MAX=
AUTH_RATE_LIMIT_RESET_MAX=

# Phase 7.8 #26 — email-keyed rate limits (per email, per WINDOW_MS).
# Layered on top of the per-IP limits above so credential stuffing across
# an IP pool (botnet, NAT, VPN) gets caught here. Window default 1h.
# Dev/test multiply 10x (matches existing getEnvLimits convention).
AUTH_EMAIL_RATE_LIMIT_SIGN_IN_MAX=
AUTH_EMAIL_RATE_LIMIT_SIGN_UP_MAX=
AUTH_EMAIL_RATE_LIMIT_MAGIC_LINK_MAX=
AUTH_EMAIL_RATE_LIMIT_RESET_PASSWORD_MAX=
AUTH_EMAIL_RATE_LIMIT_WINDOW_MS=

# Marketplace (applies to listings, categories, tags, stats, services)
MARKETPLACE_RATE_LIMIT_ANON_MAX=
MARKETPLACE_RATE_LIMIT_AUTH_MAX=

# General API fallback (all routes not matched above)
PUBLIC_RATE_LIMIT_MAX=
AUTHENTICATED_RATE_LIMIT_MAX=

# Admin API
ADMIN_RATE_LIMIT_MAX=

# Billing
BILLING_RATE_LIMIT_MAX=

# Apps
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=http://localhost:3001
NEXT_PUBLIC_PUBLISHER_URL=http://localhost:3002
NEXT_PUBLIC_ADMIN_URL=http://localhost:3003

# Worker — scheduled financial drift sweep interval (minutes, min 5)
RECONCILIATION_SWEEP_MINUTES=60

# Order cancellation and acceptance deadlines. Values are bounded positive
# integers; defaults are 24 hours and 15-minute worker sweeps.
ORDER_ACCEPTANCE_WINDOW_HOURS=24
ORDER_ACCEPTANCE_SWEEP_MINUTES=15
CANCELLATION_RESPONSE_WINDOW_HOURS=24
CANCELLATION_TIMEOUT_SWEEP_MINUTES=15

# Fee percentage for new revenue/settlement records when no PlatformSettings
# row is available. The database setting is authoritative when present.
PLATFORM_FEE_PERCENT=20

# Worker — settlement auto-approve sweep (Phase 7.3, audit #10).
# Cron now runs in the worker process, not in every API pod. The three envs
# below moved from API to worker but kept the same names for ops continuity.
#   - INTERVAL_MS: cadence in milliseconds (default 15m, min 60s)
#   - DISABLED:    "true" to skip cron registration entirely
#   - BATCH_SIZE:  max settlements processed per sweep (default 100, clamped 1..10000)
SETTLEMENT_AUTO_APPROVE_INTERVAL_MS=
SETTLEMENT_AUTO_APPROVE_DISABLED=
SETTLEMENT_AUTO_APPROVE_BATCH_SIZE=
# Slow-sweep warning threshold (default 30000ms). If a sweep takes longer
# than this, a Sentry warning fires — usually means backlog or DB stall.
SETTLEMENT_AUTO_APPROVE_SLOW_MS=

# Queue job HMAC signing (required in production, must differ from JWT_SECRET)
QUEUE_SIGNING_SECRET=

# ───────────────────────────────────────────────────────────────────────────
# Phase 7.0 — Observability (Sentry + worker health)
# ───────────────────────────────────────────────────────────────────────────
# Sentry DSN. Without this set, Sentry runs in no-op mode (dev/local default).
# Backend processes (api, worker, Next.js server/edge) read SENTRY_DSN.
# Browser bundles (Next.js client) read NEXT_PUBLIC_SENTRY_DSN at build time.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Environment tag attached to every Sentry event. Falls back to NODE_ENV if unset.
SENTRY_ENVIRONMENT=

# Phase 7.7 C — Sentry source-map upload. When SENTRY_AUTH_TOKEN is set,
# `pnpm build` uploads source maps for each Next.js app so production Sentry
# traces show source-line + filename (not minified offsets). When unset,
# upload is silently skipped. Token must have project:releases scope; create
# at https://sentry.io → Settings → Auth Tokens. In CI, configure as a
# GitHub repo secret named SENTRY_AUTH_TOKEN (ci.yml threads it in).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Release tag attached to every Sentry event for grouping by deploy.
# Typically set by CI from the commit SHA.
GIT_COMMIT_SHA=

# Worker health endpoint port (default 3004). Exposes /health, /ready, /metrics/queues.
WORKER_HEALTH_PORT=3004

# Hybrid worker runtime. Local/dev keeps "all" for one-process convenience.
# Production uses one realtime service plus on-demand/scheduled Northflank jobs.
# Values: all | realtime | on-demand | scheduled
WORKER_MODE=all
# Required only for WORKER_MODE=scheduled. See docs/WORKER_ARCHITECTURE.md.
WORKER_TASK=

# Upstash/BullMQ idle maintenance tuning. A producer marker normally wakes the
# blocking worker immediately; 300s is the low-command empty-queue ceiling.
WORKER_DRAIN_DELAY_SECONDS=300
WORKER_STALLED_INTERVAL_MS=300000
QUEUE_METRICS_CACHE_MS=1800000

# Official Northflank run-job endpoint:
# https://api.northflank.com/v1/projects/{projectId}/jobs/{jobId}/runs
# Token needs only Project > Jobs > General > Read for the target project.
# The API sends no job/customer/provider data — only an authenticated wake-up.
# A 10-minute catch-up cron is mandatory because this signal is best-effort.
WORKER_ON_DEMAND_TRIGGER_URL=
WORKER_ON_DEMAND_TRIGGER_TOKEN=
WORKER_ON_DEMAND_TRIGGER_DEBOUNCE_MS=15000
WORKER_ON_DEMAND_TRIGGER_TIMEOUT_MS=5000
WORKER_ON_DEMAND_MAX_RUNTIME_MS=600000
WORKER_SCHEDULED_TIMEOUT_MS=900000
PAYOUT_WEBHOOK_INBOX_BATCH_SIZE=100
PAYOUT_STATUS_BATCH_SIZE=50

# Worker behavior on unhandledRejection: "true" (default) exits + flushes Sentry +
# lets orchestrator restart; "false" captures-but-continues (dev convenience).
UNHANDLED_REJECTION_EXIT=true

# REQUIRED — Master key for AES-256-GCM payout encryption (64 hex chars).
# Encrypts PayoutMethod.details and PayoutProvider.config.
# Production exits at boot if missing, too short, or non-hex.
# Generate with: openssl rand -hex 32
PAYOUT_ENCRYPTION_KEY=

# Per-process Prisma connection pool max.
# Formula for multi-replica deployments:
#   max ≈ (max_connections - superuser_reserved - worker_budget) / replica_count
# Default: 10. Minimum: 1. Recommended max: 25.
# Invalid values (non-integer, zero, negative) cause a startup error.
PRISMA_POOL_MAX=10
